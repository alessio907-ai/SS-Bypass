# ============================================
# Stabile JAR Scan (Erweiterte Benutzer-Ordner)
# ============================================

Write-Host "=== Stabiler JAR Scan ===" -ForegroundColor Cyan
Write-Host "Scannt viele typische Benutzer- & Minecraft-Ordner" -ForegroundColor Yellow
Write-Host ""

# Basisnamen (UNVERÄNDERT)
$baseNames = @(
    "meteorclient","wurstclient","argon","krypton","catlean",
    "betterping","clickcrystal","killaura","crystalaura",
    "autoclick","triggerbot","aimassist","autocrystal",
    "wtap","tpaura","autototem","playeresp","storageesp",
    "system"
)

$patterns = $baseNames | ForEach-Object { "^$_.*" }

$foundItems = @()
$totalCount = 0

# 🔎 ERWEITERTE ORDNERLISTE (nur das wurde erweitert)
$scanFolders = @(
    # Standard User Ordner
    "$env:USERPROFILE\Desktop",
    "$env:USERPROFILE\Downloads",
    "$env:USERPROFILE\Documents",
    "$env:USERPROFILE\Pictures",
    "$env:USERPROFILE\Videos",
    "$env:USERPROFILE\Music",

    # AppData
    "$env:APPDATA",
    "$env:LOCALAPPDATA",
    "$env:LOCALAPPDATA\Temp",

    # Minecraft & Launcher
    "$env:APPDATA\.minecraft",
    "$env:LOCALAPPDATA\.minecraft",
    "$env:APPDATA\.tlauncher",
    "$env:APPDATA\.lunarclient",
    "$env:APPDATA\.feather",
    "$env:APPDATA\.badlion",
    "$env:APPDATA\.curseforge",
    "$env:APPDATA\PrismLauncher",
    "$env:APPDATA\MultiMC",

    # Öffentliche Benutzerordner
    "C:\Users\Public\Desktop",
    "C:\Users\Public\Downloads",
    "C:\Users\Public\Documents",

    # Temp & allgemeine Speicherorte
    "C:\Temp",
    "C:\Windows\Temp"
)

foreach ($folder in $scanFolders | Select-Object -Unique) {
    if (-not (Test-Path $folder)) { continue }

    Write-Host "Scanne: $folder" -ForegroundColor Gray

    try {
        Get-ChildItem $folder -Recurse -Filter *.jar -ErrorAction SilentlyContinue | ForEach-Object {
            $totalCount++
            $jarName = $_.Name.ToLower()
            foreach ($pattern in $patterns) {
                if ($jarName -match $pattern) {
                    $foundItems += [PSCustomObject]@{
                        JAR   = $_.Name
                        Größe = "{0:N2} MB" -f ($_.Length / 1MB)
                        Pfad  = $_.FullName
                    }
                    break
                }
            }
        }
    }
    catch {
        # Fehler ignorieren
    }
}

# Ergebnisse
Write-Host ""
Write-Host "=== ERGEBNIS ===" -ForegroundColor Cyan
Write-Host "Gescannt: $totalCount JAR-Dateien"
Write-Host "Verdächtig: $($foundItems.Count)"

if ($foundItems.Count -gt 0) {
    $foundItems | Sort-Object Pfad -Unique | Format-Table -AutoSize
} else {
    Write-Host "Keine passenden Dateinamen gefunden." -ForegroundColor Green
}

Write-Host ""
Write-Host "Scan abgeschlossen. Es wurde NICHTS verändert." -ForegroundColor Yellow
