# ============================================
# FULL PC JAR SCAN (READ-ONLY)
# Scannt ALLE .jar Dateien auf allen Laufwerken
# Es wird NICHTS gelöscht!
# ============================================

Write-Host "=== Vollständiger JAR-Scan gestartet ===" -ForegroundColor Cyan
Write-Host "Es werden alle .jar Dateien auf allen Laufwerken geprüft." -ForegroundColor Yellow
Write-Host ""

# Suchbegriffe
$keywords = @(
    "clickcrystal","argon","system.b1.5","system.b1.6","system.b1.7",
    "meteor","wurst","krypton","aristois","impact",
    "kami","lambda","rusher","wolfram","vengeance",
    "novoline","sigma","jigsaw","zenith","pyro",
    "cyanide","ghost","reach","killaura","xray",
    "nuker","autoclick"
)

# Systemlaufwerke automatisch erkennen
$drives = Get-PSDrive -PSProvider FileSystem | Where-Object { $_.Free -ne $null }

$foundItems = @()
$totalScanned = 0

foreach ($drive in $drives) {

    Write-Host "Scanne Laufwerk: $($drive.Name):\" -ForegroundColor DarkGray

    Get-ChildItem "$($drive.Name):\" -Recurse -Filter *.jar -Force -ErrorAction SilentlyContinue |
    ForEach-Object {

        $totalScanned++

        # Fortschritt alle 1000 Dateien
        if ($totalScanned % 1000 -eq 0) {
            Write-Host "Gescannt: $totalScanned JAR-Dateien..." -ForegroundColor Gray
        }

        $lower = $_.FullName.ToLower()

        foreach ($word in $keywords) {
            if ($lower -like "*$word*") {

                $foundItems += [PSCustomObject]@{
                    Name  = $_.Name
                    Größe = "{0:N2} MB" -f ($_.Length / 1MB)
                    Pfad  = $_.FullName
                    Datum = $_.LastWriteTime
                    Laufwerk = $drive.Name
                }

                break
            }
        }
    }
}

Write-Host ""
Write-Host "=== ERGEBNIS ===" -ForegroundColor Cyan
Write-Host "Gesamt gescannte JAR-Dateien: $totalScanned" -ForegroundColor White
Write-Host "Verdächtige Dateien: $($foundItems.Count)" -ForegroundColor White

if ($foundItems.Count -gt 0) {
    $foundItems | Sort-Object Pfad -Unique | Format-Table -AutoSize
}
else {
    Write-Host "Keine verdächtigen JAR-Dateien gefunden." -ForegroundColor Green
}

Write-Host ""
Write-Host "Scan abgeschlossen. Es wurde NICHTS verändert." -ForegroundColor Yellow
