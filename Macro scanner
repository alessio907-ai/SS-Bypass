# ============================================
# C:\ JAR STRING SCAN (kein Namens-Check)
# Nur Anzeige – nichts wird gelöscht!
# ============================================

Write-Host "=== Vollständiger C:\ JAR STRING Scan ===" -ForegroundColor Cyan
Write-Host "Durchsucht .class Dateien nach verdächtigen STRINGS." -ForegroundColor Yellow
Write-Host ""

Add-Type -AssemblyName System.IO.Compression.FileSystem

# Verdächtige Fragmente
$frags=@(
"killaura","crystalaura","autoclick","triggerbot","aimassist","autocrystal","clickcrystal",
"anchormacro","wtap","tpaura","placecrystal","breakcrystal","autototem","autoinv",
"playeresp","storageesp","fastexp","doubleanchor","autoexplode"
)

$tempRoot = "$env:TEMP\JarScanTemp"
if(Test-Path $tempRoot){ Remove-Item $tempRoot -Recurse -Force -ErrorAction SilentlyContinue }
New-Item -ItemType Directory -Path $tempRoot | Out-Null

$foundItems = @()
$count = 0

Get-ChildItem "C:\" -Recurse -Filter *.jar -Force -ErrorAction SilentlyContinue |
ForEach-Object {

    $count++
    if ($count % 100 -eq 0) {
        Write-Host "Gescannt: $count JAR-Dateien..." -ForegroundColor Gray
    }

    $jarPath = $_.FullName
    $extractPath = Join-Path $tempRoot ([Guid]::NewGuid().ToString())

    try {
        # Extrahieren
        [System.IO.Compression.ZipFile]::ExtractToDirectory($jarPath, $extractPath)

        # Nur CLASS Dateien scannen
        $classes = Get-ChildItem $extractPath -Recurse -Filter "*.class" -ErrorAction SilentlyContinue

        foreach($c in $classes){
            try{
                $bytes = [System.IO.File]::ReadAllBytes($c.FullName)
                $text  = [System.Text.Encoding]::ASCII.GetString($bytes).ToLower()

                foreach($frag in $frags){
                    if($text.Contains($frag)){

                        $foundItems += [PSCustomObject]@{
                            JAR    = $_.Name
                            Treffer= $frag
                            Größe  = "{0:N2} MB" -f ($_.Length / 1MB)
                            Pfad   = $jarPath
                        }

                        break
                    }
                }
            }
            catch{}
        }

        Remove-Item $extractPath -Recurse -Force -ErrorAction SilentlyContinue
    }
    catch{
        # kaputte JAR ignorieren
    }
}

Write-Host ""
Write-Host "=== ERGEBNIS ===" -ForegroundColor Cyan
Write-Host "Gescannt: $count JAR-Dateien"
Write-Host "Verdächtig: $($foundItems.Count)"

if ($foundItems.Count -gt 0) {
    $foundItems | Sort-Object Pfad -Unique | Format-Table -AutoSize
}
else {
    Write-Host "Keine verdächtigen Strings gefunden." -ForegroundColor Green
}

Write-Host ""
Write-Host "Scan abgeschlossen. Es wurde NICHTS verändert." -ForegroundColor Yellow
