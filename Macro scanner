# ============================================
# Minecraft JAR NAMEN Scan (Stabile Version)
# Nur Anzeige – nichts wird gelöscht!
# ============================================

Write-Host "=== Minecraft JAR Scan ===" -ForegroundColor Cyan

$scanPath = "$env:APPDATA\.minecraft"

if (!(Test-Path $scanPath)) {
    Write-Host "Minecraft-Ordner nicht gefunden!" -ForegroundColor Red
    Write-Host "Pfad: $scanPath"
    exit
}

Write-Host "Scan-Pfad: $scanPath" -ForegroundColor Yellow
Write-Host ""

# Namen die erkannt werden sollen (Beginnt-mit)
$baseNames = @(
    "meteorclient",
    "wurstclient",
    "argon",
    "krypton",
    "catlean",
    "betterping",
    "clickcrystal",
    "killaura",
    "crystalaura",
    "autoclick",
    "triggerbot",
    "aimassist",
    "autocrystal",
    "wtap",
    "tpaura",
    "autototem",
    "playeresp",
    "storageesp",
    "system"
)

$patterns = $baseNames | ForEach-Object { "^$_.*" }

$foundItems = @()
$count = 0

Get-ChildItem $scanPath -Recurse -Filter *.jar -ErrorAction SilentlyContinue |
ForEach-Object {

    $count++
    $jarName = $_.Name.ToLower()

    foreach($pattern in $patterns){
        if($jarName -match $pattern){

            $foundItems += [PSCustomObject]@{
                JAR   = $_.Name
                Größe = "{0:N2} MB" -f ($_.Length / 1MB)
                Pfad  = $_.FullName
            }

            break
        }
    }
}

Write-Host ""
Write-Host "=== ERGEBNIS ===" -ForegroundColor Cyan
Write-Host "Gescannt: $count JAR-Dateien"
Write-Host "Verdächtig: $($foundItems.Count)"

if ($foundItems.Count -gt 0) {
    $foundItems | Sort-Object Pfad -Unique | Format-Table -AutoSize
}
else {
    Write-Host "Keine passenden Dateinamen gefunden." -ForegroundColor Green
}

Write-Host ""
Write-Host "Scan abgeschlossen. Es wurde NICHTS verändert." -ForegroundColor Yellow
