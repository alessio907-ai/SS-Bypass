                (Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue) -match "prestige|blur|inject"
            } | ForEach-Object {
                Add-Found -Path $_.FullName -Type "BROWSER-EXTENSION" -Details "Mögliche Prestige-Erweiterung"
            }
        }
    }
}

# ============================= FUNKTION: STARTUP-ORDNER SCANNEN =============================
function Scan-Startup {
    Write-Host "`n🚀 Scanne Startup-Ordner..." -ForegroundColor $Colors.Info
    
    $startupPaths = @(
        "$env:APPDATA\Microsoft\Windows\Start Menu\Programs\Startup",
        "C:\ProgramData\Microsoft\Windows\Start Menu\Programs\Startup",
        "$env:LOCALAPPDATA\Microsoft\Windows\Start Menu\Programs\Startup"
    )
    
    foreach ($path in $startupPaths) {
        if (Test-Path $path) {
            Get-ChildItem $path -File -ErrorAction SilentlyContinue | ForEach-Object {
                foreach ($term in $PrestigeTerms) {
                    if ($_.Name -match $term -or (Get-Content $_.FullName -Raw -ErrorAction SilentlyContinue) -match $term) {
                        Add-Found -Path $_.FullName -Type "STARTUP-EINTRAG" -Details "Autostart: $($_.Name)"
                        break
                    }
                }
            }
        }
    }
}

# ============================= FUNKTION: MINIDUMPS SCANNEN =============================
function Scan-Minidumps {
    Write-Host "`n💥 Scanne Minidumps und Crash-Reports..." -ForegroundColor $Colors.Info
    
    $dumpPaths = @(
        "$env:LOCALAPPDATA\CrashDumps",
        "$env:SystemRoot\Minidump",
        "$env:SystemRoot\LiveKernelReports",
        "$env:USERPROFILE\Desktop\*.dmp",
        "$env:USERPROFILE\Desktop\*.mdmp",
        "$env:USERPROFILE\Desktop\*.hdmp",
        "$env:APPDATA\.minecraft\*.dmp",
        "$env:LOCALAPPDATA\Temp\*.dmp"
    )
    
    foreach ($pattern in $dumpPaths) {
        Get-ChildItem -Path $pattern -ErrorAction SilentlyContinue | ForEach-Object {
            if ($_.Length -gt 0) {
                Add-Found -Path $_.FullName -Type "MINIDUMP" -Details "Größe: $([math]::Round($_.Length/1MB,2)) MB | Geändert: $($_.LastWriteTime)"
            }
        }
    }
}

# ============================= FUNKTION: PRESTIGE-PROZESS-ANALYSE =============================
function Analyze-PrestigeProcess {
    param([string]$ExePath)
    
    Write-Host "`n🔬 Analysiere Prestige-Prozess: $ExePath" -ForegroundColor $Colors.Info
    
    if (-not (Test-Path $ExePath)) {
        Write-Host "❌ Datei nicht gefunden!" -ForegroundColor $Colors.Error
        return
    }
    
    $file = Get-Item $ExePath
    
    # Datei-Info
    Add-Found -Path $ExePath -Type "PRESTIGE-EXE" -Details "Größe: $([math]::Round($file.Length/1MB,2)) MB | Erstellt: $($file.CreationTime) | Geändert: $($file.LastWriteTime)"
    
    # Versuche Datei-Version zu lesen
    try {
        $versionInfo = $file.VersionInfo
        Add-Found -Path $ExePath -Type "PRESTIGE-EXE" -Details "Version: $($versionInfo.FileVersion) | Produkt: $($versionInfo.ProductName) | Beschreibung: $($versionInfo.FileDescription)"
    } catch {}
    
    # Prüfe ob Prozess läuft
    $processName = [System.IO.Path]::GetFileNameWithoutExtension($ExePath)
    $proc = Get-Process -Name $processName -ErrorAction SilentlyContinue
    if ($proc) {
        Add-Found -Path "PROZESS" -Type "PRESTIGE-LAUFEND" -Details "PID: $($proc.Id) | Startzeit: $($proc.StartTime) | CPU: $($proc.CPU) | Speicher: $([math]::Round($proc.WorkingSet/1MB,2)) MB"
        
        # Zeige Kommandozeile
        try {
            $cmdLine = (Get-WmiObject Win32_Process -Filter "ProcessId=$($proc.Id)").CommandLine
            Add-Found -Path "PROZESS" -Type "PRESTIGE-COMMAND" -Details "Kommandozeile: $cmdLine"
        } catch {}
    }
}

# ============================= FUNKTION: BERICHT ERSTELLEN =============================
function Generate-Report {
    param([string]$OutputPath)
    
    $endTime = Get-Date
    $duration = $endTime - $Global:ScanStartTime
    
    $report = @"
╔══════════════════════════════════════════════════════════════════════════════════════╗
║                         PRESTIGE CLIENT SCAN REPORT                                  ║
╚══════════════════════════════════════════════════════════════════════════════════════╝

SCAN INFORMATION
═══════════════════════════════════════════════════════════════════════════════════════
Script Version : $Version
Scan Date      : $ScanDate
Duration       : $($duration.Hours)h $($duration.Minutes)m $($duration.Seconds)s
User           : $env:USERNAME
Computer       : $env:COMPUTERNAME
OS             : $(Get-WmiObject Win32_OperatingSystem).Caption

SCAN STATISTICS
═══════════════════════════════════════════════════════════════════════════════════════
Ordner gescannt    : $Global:TotalDirsScanned
Dateien gescannt   : $Global:TotalFilesScanned
Funde gesamt       : $Global:FoundCount
Fehler             : $($Global:Errors.Count)
Warnungen          : $($Global:Warnings.Count)

GEFUNDENE PRESTIGE-SPUREN
═══════════════════════════════════════════════════════════════════════════════════════

"@
    
    $grouped = $Global:FoundItems | Group-Object Type
    foreach ($group in $grouped) {
        $report += "`n[$($group.Name)] - $($group.Count) Funde"
        $report += "-" * 80 + "`n"
        
        $group.Group | Sort-Object Path | ForEach-Object {
            $report += "📁 $($_.Path)`n"
            $report += "   📝 $($_.Details) | ⏰ $($_.Time)`n"
        }
        $report += "`n"
    }
    
    $report += @"

FEHLER
═══════════════════════════════════════════════════════════════════════════════════════
"@
    
    if ($Global:Errors.Count -eq 0) {
        $report += "`nKeine Fehler aufgetreten.`n"
    } else {
        $Global:Errors | ForEach-Object { $report += "❌ $_`n" }
    }
    
    $report += @"

WARNUNGEN
═══════════════════════════════════════════════════════════════════════════════════════
"@
    
    if ($Global:Warnings.Count -eq 0) {
        $report += "`nKeine Warnungen.`n"
    } else {
        $Global:Warnings | ForEach-Object { $report += "⚠️ $_`n" }
    }
    
    $report += @"

EMPFEHLUNGEN
═══════════════════════════════════════════════════════════════════════════════════════
"@
    
    if ($Global:FoundCount -gt 0) {
        $report += @"
✅ Prestige Client wurde auf Ihrem System gefunden!
✅ Die gefundenen Dateien können Sie manuell löschen.
✅ Empfehlung: Führen Sie einen Virenscan mit aktuellem Scanner durch.
✅ Überprüfen Sie die Startup-Ordner und Task-Scheduler.
"@
    } else {
        $report += @"
❌ Keine Prestige Client Spuren gefunden.
✅ Ihr System scheint sauber zu sein.
✅ Falls Sie den Client trotzdem installiert haben, wurde er möglicherweise gelöscht.
"@
    }
    
    $report += @"


═══════════════════════════════════════════════════════════════════════════════════════
Ende des Berichts - $((Get-Date).ToString("yyyy-MM-dd HH:mm:ss"))
═══════════════════════════════════════════════════════════════════════════════════════
"@
    
    # Bericht speichern
    $report | Out-File -FilePath "$OutputPath\Prestige_Scan_Report.txt" -Encoding UTF8
    $Global:FoundItems | Export-Csv -Path "$OutputPath\Prestige_Funde.csv" -NoTypeInformation -Delimiter ";"
    $Global:FoundItems | ConvertTo-Json -Depth 3 | Out-File -FilePath "$OutputPath\Prestige_Funde.json"
    
    Write-Host "`n📄 Bericht gespeichert in: $OutputPath" -ForegroundColor $Colors.Success
}

# ============================= HAUPTFUNKTION =============================
function Start-MainScan {
    Show-Header
    
    Write-Host "Starte Prestige Client Deep Scan v$Version" -ForegroundColor $Colors.Header
    Write-Host "Scan wird durchgeführt von: $env:USERNAME@$env:COMPUTERNAME" -ForegroundColor $Colors.Info
    Write-Host "Startzeit: $ScanDate" -ForegroundColor $Colors.Info
    Write-Host ""
    
    # Admin-Prüfung
    $isAdmin = ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")
    if (-not $isAdmin) {
        Write-Host "⚠️ Achtung: Nicht als Administrator ausgeführt!" -ForegroundColor $Colors.Warning
        Write-Host "   Einige Bereiche (Registry, Systemordner) können nicht gescannt werden." -ForegroundColor $Colors.Warning
        $Global:Warnings += "Nicht als Administrator ausgeführt - eingeschränkter Scan"
    } else {
        Write-Host "✅ Als Administrator ausgeführt - Vollzugriff!" -ForegroundColor $Colors.Success
    }
    
    Write-Host ""
    
    # ===== DATEISYSTEM SCANNEN =====
    Write-Host "╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                 DATEISYSTEM-SCAN                 ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    
    $pathIndex = 0
    foreach ($path in $ScanPaths) {
        $pathIndex++
        $percent = [math]::Round(($pathIndex / $ScanPaths.Count) * 100)
        Show-Progress -Activity "Scanne Pfad $pathIndex von $($ScanPaths.Count)" -Status $path -PercentComplete $percent
        
        if (Test-Path $path) {
            Scan-FileSystem -Path $path -MaxDepth 15
        }
    }
    Write-Host ""
    
    # ===== REGISTRY SCANNEN =====
    if ($isAdmin) {
        Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
        Write-Host "║                   REGISTRY-SCAN                   ║" -ForegroundColor $Colors.Header
        Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
        Scan-Registry
    }
    
    # ===== PROZESSE SCANNEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   PROZESS-SCAN                    ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-Processes
    
    # ===== NETZWERK SCANNEN =====
    if ($isAdmin) {
        Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
        Write-Host "║                   NETZWERK-SCAN                   ║" -ForegroundColor $Colors.Header
        Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
        Scan-Network
    }
    
    # ===== TASK-SCHEDULER SCANNEN =====
    if ($isAdmin) {
        Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
        Write-Host "║                   TASK-SCHEDULER-SCAN              ║" -ForegroundColor $Colors.Header
        Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
        Scan-TaskScheduler
    }
    
    # ===== DIENSTE SCANNEN =====
    if ($isAdmin) {
        Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
        Write-Host "║                   DIENSTE-SCAN                    ║" -ForegroundColor $Colors.Header
        Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
        Scan-Services
    }
    
    # ===== PAPIERKORB SCANNEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   PAPIERKORB-SCAN                  ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-RecycleBin
    
    # ===== PRESTIGE-SPEZIFISCHE SUCHE =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║              PRESTIGE-SPEZIFISCHE SUCHE             ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-PrestigeSpecific
    
    # ===== JVM-PARAMETER SCANNEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   JVM-PARAMETER-SCAN               ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-JVMParameters
    
    # ===== BROWSER-EXTENSIONS SCANNEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║              BROWSER-EXTENSIONS-SCAN                ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-BrowserExtensions
    
    # ===== STARTUP SCANNEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   STARTUP-SCAN                     ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-Startup
    
    # ===== MINIDUMPS SCANNEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   MINIDUMP-SCAN                    ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Scan-Minidumps
    
    # ===== SPEZIELLE DESKTOP-EXE ANALYSE =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║              DESKTOP-EXE ANALYSE                   ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    
    $desktopExes = Get-ChildItem "$env:USERPROFILE\Desktop" -File | Where-Object { $_.Extension -match "\.(exe|jar|bat|cmd|ps1)" }
    foreach ($exe in $desktopExes) {
        foreach ($term in $PrestigeTerms) {
            if ($exe.Name -match $term) {
                Analyze-PrestigeProcess -ExePath $exe.FullName
                break
            }
        }
    }
    
    # ===== ERGEBNISSE ANZEIGEN =====
    Write-Host "`n╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   SCAN-ERGEBNIS                    ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    
    Write-Host ""
    Write-Host "📊 STATISTIK:" -ForegroundColor $Colors.Header
    Write-Host "   ├─ Ordner gescannt: $Global:TotalDirsScanned" -ForegroundColor $Colors.Info
    Write-Host "   ├─ Dateien gescannt: $Global:TotalFilesScanned" -ForegroundColor $Colors.Info
    Write-Host "   ├─ Funde gesamt: $Global:FoundCount" -ForegroundColor $(if ($Global:FoundCount -gt 0) { $Colors.Found } else { $Colors.Success })
    Write-Host "   └─ Fehler: $($Global:Errors.Count)" -ForegroundColor $(if ($Global:Errors.Count -gt 0) { $Colors.Error } else { $Colors.Success })
    
    if ($Global:FoundCount -gt 0) {
        Write-Host ""
        Write-Host "🔥 GEFUNDENE PRESTIGE-SPUREN:" -ForegroundColor $Colors.Found
        $Global:FoundItems | Group-Object Type | ForEach-Object {
            Write-Host "   [$($_.Name)] - $($_.Count) Funde" -ForegroundColor $Colors.Warning
        }
        
        Write-Host ""
        Write-Host "📁 DETAILS DER FUNDE:" -ForegroundColor $Colors.Header
        $Global:FoundItems | Sort-Object Type, Path | ForEach-Object {
            Write-Host "   🔴 $($_.Type)" -ForegroundColor $Colors.Found
            Write-Host "      📍 $($_.Path)" -ForegroundColor $Colors.Path
            Write-Host "      📝 $($_.Details)" -ForegroundColor $Colors.Info
            Write-Host "      ⏰ $($_.Time)" -ForegroundColor $Colors.Warning
            Write-Host ""
        }
    } else {
        Write-Host ""
        Write-Host "✅ KEINE Prestige Client Spuren gefunden!" -ForegroundColor $Colors.Success
        Write-Host "   Ihr System scheint sauber zu sein." -ForegroundColor $Colors.Info
    }
    
    # ===== BERICHT ERSTELLEN =====
    if ($Global:FoundCount -gt 0 -or $Force) {
        New-Item -ItemType Directory -Path $OutputPath -Force | Out-Null
        Generate-Report -OutputPath $OutputPath
        
        Write-Host ""
        Write-Host "📁 Bericht wurde gespeichert in: $OutputPath" -ForegroundColor $Colors.Success
        Write-Host "   - Prestige_Scan_Report.txt (Textbericht)" -ForegroundColor $Colors.Info
        Write-Host "   - Prestige_Funde.csv (CSV-Format)" -ForegroundColor $Colors.Info
        Write-Host "   - Prestige_Funde.json (JSON-Format)" -ForegroundColor $Colors.Info
        
        # Automatisch öffnen wenn gewünscht
        if ($AutoCopy) {
            explorer $OutputPath
        }
    }
    
    # ===== ABSCHLUSS =====
    $endTime = Get-Date
    $duration = $endTime - $Global:ScanStartTime
    
    Write-Host ""
    Write-Host "╔" + ("═" * 50) + "╗" -ForegroundColor $Colors.Separator
    Write-Host "║                   SCAN ABGESCHLOSSEN                ║" -ForegroundColor $Colors.Header
    Write-Host "╚" + ("═" * 50) + "╝" -ForegroundColor $Colors.Separator
    Write-Host ""
    Write-Host "✅ Scan erfolgreich beendet!" -ForegroundColor $Colors.Success
    Write-Host "⏱️  Dauer: $($duration.Hours)h $($duration.Minutes)m $($duration.Seconds)s" -ForegroundColor $Colors.Info
    Write-Host "📊 Insgesamt $Global:TotalFilesScanned Dateien in $Global:TotalDirsScanned Ordnern durchsucht" -ForegroundColor $Colors.Info
    Write-Host ""
    Write-Host "Press any key to exit..." -ForegroundColor $Colors.Warning
    $null = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown")
}

