Function Open-CDDrive
{
    Add-Type -TypeDefinition  @'
    using System;
    using System.Runtime.InteropServices;
    namespace CDROM {
        public class Commands {
            [DllImport("winmm.dll")]
            static extern Int32 mciSendString(string command, string buffer, int bufferSize, IntPtr hwndCallback);
            public static void Eject() { mciSendString("set CDAudio door open", "", 127, IntPtr.Zero); }
            public static void Close() { mciSendString("set CDAudio door closed", "", 127, IntPtr.Zero); }
        }
    }  
'@
    [CDROM.Commands]::Eject()
}

Function Close-CDDrive
{
    Add-Type -TypeDefinition  @'
    using System;
    using System.Runtime.InteropServices;
    namespace CDROM {
        public class Commands {
            [DllImport("winmm.dll")]
            static extern Int32 mciSendString(string command, string buffer, int bufferSize, IntPtr hwndCallback);
            public static void Close() { mciSendString("set CDAudio door closed", "", 127, IntPtr.Zero); }
        }
    }  
'@
    [CDROM.Commands]::Close()
}

