# ===== ULTIMATIVE PRESTIGE-ORDNER SUCHE =====

Write-Host "Scanne nach Prestige-Ordnern mit Logs/Crashes..." -ForegroundColor Cyan

$searchPaths = @(
    "$env:USERPROFILE\Desktop",
    "$env:USERPROFILE\Downloads",
    "$env:APPDATA",
    "$env:LOCALAPPDATA",
    "$env:ProgramData",
    "C:\"
)

$foundFolders = @()

foreach ($path in $searchPaths) {
    if (Test-Path $path) {
        Get-ChildItem -Path $path -Directory -Recurse -ErrorAction SilentlyContinue | 
        Where-Object { 
            $_.Name -like "*prestige*" -or 
            $_.Name -like "*Prestige*" -or
            $_.Name -like "*inject*" -or
            $_.FullName -like "*\Prestige\*" -or
            $_.FullName -like "*\prestige-client\*"
        } |
        ForEach-Object {
            Write-Host "🚨 PRESTIGE ORDENER GEFUNDEN: $($_.FullName)" -ForegroundColor Red
            
            # Zeige Unterordner-Struktur
            Write-Host "  └─ Unterordner:" -ForegroundColor Yellow
            Get-ChildItem -Path $_.FullName -Directory | ForEach-Object {
                Write-Host "      ├─ $($_.Name)" -ForegroundColor Gray
            }
            
            # Zeige LOG-Dateien
            $logs = Get-ChildItem -Path $_.FullName -File -Recurse -Include "*.log", "*.txt", "*.json", "*.crash", "*.dmp", "*.mdmp"
            if ($logs) {
                Write-Host "  └─ LOG-DATEIEN:" -ForegroundColor Yellow
                $logs | ForEach-Object {
                    $size = [math]::Round($_.Length/1KB, 2)
                    Write-Host "      ├─ $($_.Name) (${size} KB) - $($_.LastWriteTime)" -ForegroundColor Green
                }
            }
            
            $foundFolders += $_.FullName
        }
    }
}

# Speziell nach Crash-Reports suchen
Write-Host "`n[2] Scanne speziell nach Crash-Reports..." -ForegroundColor Cyan

$crashLocations = @(
    "$env:USERPROFILE\Desktop\*crash*",
    "$env:USERPROFILE\Downloads\*crash*",
    "$env:APPDATA\*crash*",
    "$env:LOCALAPPDATA\Temp\*crash*"
)

foreach ($pattern in $crashLocations) {
    Get-ChildItem -Path $pattern -Recurse -ErrorAction SilentlyContinue | 
    Where-Object { $_ -is [System.IO.FileInfo] } |
    ForEach-Object {
        if ($_.Name -match "prestige|Prestige|client|inject") {
            Write-Host "🚨 CRASH-REPORT GEFUNDEN: $($_.FullName)" -ForegroundColor Red
            Write-Host "    Datum: $($_.LastWriteTime)" -ForegroundColor Yellow
            Write-Host "    Größe: $([math]::Round($_.Length/1KB, 2)) KB" -ForegroundColor Yellow
            $foundItems += $_.FullName
        }
    }
}

# Zusammenfassung
Write-Host "`n========== ERGEBNIS ==========" -ForegroundColor Magenta
if ($foundFolders.Count -gt 0) {
    Write-Host "GEFUNDENE PRESTIGE-ORDNER:" -ForegroundColor Red
    $foundFolders | ForEach-Object { Write-Host "  📁 $_" -ForegroundColor Yellow }
} else {
    Write-Host "❌ KEINE Prestige-Ordner gefunden!" -ForegroundColor Red
}

Write-Host "`nTipp: Prestige-Ordner heißen oft: .prestige, Prestige, prestige-client, prestige_data" -ForegroundColor Cyan
