# ============================= FUNKTION: PRESTIGE-SPEZIFISCHE SUCHE =============================
function Scan-PrestigeSpecific {
    Write-Host "`n🎯 Führe Prestige-spezifische Tiefensuche durch..." -ForegroundColor $Colors.Info
    
    # Spezifische Prestige-Pfade
    $specificPaths = @(
        "$env:USERPROFILE\.prestige",
        "$env:USERPROFILE\.blur",
        "$env:USERPROFILE\.blur-config",
        "$env:USERPROFILE\Desktop\.blur-config",
        "$env:USERPROFILE\Prestige",
        "$env:USERPROFILE\Prestige Client",
        "$env:APPDATA\Prestige",
        "$env:APPDATA\.prestige",
        "$env:LOCALAPPDATA\Prestige",
        "$env:LOCALAPPDATA\Temp\prestige",
        "$env:LOCALAPPDATA\Temp\.prestige",
        "$env:LOCALAPPDATA\Temp\prestige_*",
        "$env:LOCALAPPDATA\Temp\blur_*",
        "$env:LOCALAPPDATA\Temp\.blur_*",
        "$env:ProgramData\Prestige",
        "C:\Prestige",
        "C:\Program Files\Prestige",
        "C:\Program Files (x86)\Prestige"
    )
    
    foreach ($path in $specificPaths) {
        if (Test-Path $path) {
            Add-Found -Path $path -Type "PRESTIGE-SPEZIFISCH" -Details "Existiert: $path"
            
            # Rekursiv den Inhalt anzeigen
            Get-ChildItem $path -Recurse -Force -ErrorAction SilentlyContinue | ForEach-Object {
                if ($_.PSIsContainer) {
                    Add-Found -Path $_.FullName -Type "PRESTIGE-UNTERORDNER" -Details "In $path"
                } else {
                    Add-Found -Path $_.FullName -Type "PRESTIGE-DATEI" -Details "In $path | Größe: $([math]::Round($_.Length/1KB,2)) KB"
                }
            }
        }
    }
    
    # Nach Prestige-Logs suchen
    $logPaths = @(
        "$env:LOCALAPPDATA\Temp\*prestige*.log",
        "$env:LOCALAPPDATA\Temp\*blur*.log",
        "$env:LOCALAPPDATA\Temp\prestige_*\*.log",
        "$env:LOCALAPPDATA\Temp\prestige_*\crash-*",
        "$env:USERPROFILE\Desktop\*prestige*.log",
        "$env:USERPROFILE\Desktop\*crash*.log",
        "$env:APPDATA\.minecraft\logs\*prestige*",
        "$env:APPDATA\.minecraft\crash-reports\*prestige*"
    )
    
    foreach ($pattern in $logPaths) {
        Get-ChildItem -Path $pattern -ErrorAction SilentlyContinue | ForEach-Object {
            Add-Found -Path $_.FullName -Type "PRESTIGE-LOG" -Details "Log-Datei | Größe: $([math]::Round($_.Length/1KB,2)) KB | Geändert: $($_.LastWriteTime)"
            
            # Erste 10 Zeilen des Logs anzeigen
            try {
                $firstLines = Get-Content $_.FullName -TotalCount 10 -ErrorAction SilentlyContinue
                Add-Found -Path "LOG-INHALT" -Type "PRESTIGE-LOG" -Details "Erste Zeilen von $($_.Name):`n$($firstLines -join '`n')"
            } catch {}
        }
    }
}

