# ============================= FUNKTION: PROGRESS ANZEIGEN =============================
function Show-Progress {
    param([string]$Activity, [string]$Status, [int]$PercentComplete)
    
    $width = 50
    $progress = [math]::Floor($PercentComplete / 2)
    $bar = "[" + ("█" * $progress) + ("░" * ($width - $progress)) + "]"
    
    Write-Host "`r$bar $PercentComplete% - $Activity : $Status" -NoNewline -ForegroundColor $Colors.Info
}

# ============================= FUNKTION: FUND MELDEN =============================
function Add-Found {
    param(
        [string]$Path,
        [string]$Type,
        [string]$Details = ""
    )
    
    $Global:FoundCount++
    $Global:FoundItems += [PSCustomObject]@{
        Index = $Global:FoundCount
        Path = $Path
        Type = $Type
        Details = $Details
        Time = Get-Date -Format "HH:mm:ss"
    }
    
    Write-Host ""
    Write-Host "🔥 FUND #$($Global:FoundCount): " -ForegroundColor $Colors.Found -NoNewline
    Write-Host "$Type" -ForegroundColor $Colors.Warning
    Write-Host "   📁 $Path" -ForegroundColor $Colors.Path
    if ($Details) { Write-Host "   ℹ️ $Details" -ForegroundColor $Colors.Info }
}

# ============================= FUNKTION: DATEISYSTEM SCANNEN =============================
function Scan-FileSystem {
    param([string]$Path, [int]$Depth = 0, [int]$MaxDepth = 10)
    
    if ($Depth -gt $MaxDepth) { return }
    if (-not (Test-Path $Path)) { return }
    
    try {
        # Ordner scannen
        $dirs = Get-ChildItem -Path $Path -Directory -Force -ErrorAction SilentlyContinue
        foreach ($dir in $dirs) {
            $Global:TotalDirsScanned++
            
            # Prüfe Ordnernamen
            foreach ($term in $PrestigeTerms) {
                if ($dir.Name -like "*$term*") {
                    Add-Found -Path $dir.FullName -Type "PRESTIGE-ORDNER" -Details "Ordnername: $($dir.Name)"
                    break
                }
            }
            
            # Rekursiv weiterscannen
            Scan-FileSystem -Path $dir.FullName -Depth ($Depth + 1) -MaxDepth $MaxDepth
        }
        
        # Dateien scannen
        $files = Get-ChildItem -Path $Path -File -Force -ErrorAction SilentlyContinue
        foreach ($file in $files) {
            $Global:TotalFilesScanned++
            
            # Prüfe Dateinamen
            foreach ($term in $PrestigeTerms) {
                if ($file.Name -like "*$term*") {
                    Add-Found -Path $file.FullName -Type "PRESTIGE-DATEI" -Details "Dateiname: $($file.Name) | Größe: $([math]::Round($file.Length/1KB,2)) KB | Geändert: $($file.LastWriteTime)"
                    break
                }
            }
            
            # Prüfe Datei-Inhalt bei bestimmten Extensions
            if ($file.Extension -match "\.(exe|dll|jar|json|cfg|conf|properties|txt|log|bat|ps1|vbs|js)$") {
                try {
                    if ($file.Length -lt 1MB) {  # Nur kleine Dateien einlesen
                        $content = Get-Content $file.FullName -Raw -ErrorAction SilentlyContinue
                        if ($content) {
                            foreach ($term in $PrestigeTerms) {
                                if ($content -match $term) {
                                    Add-Found -Path $file.FullName -Type "PRESTIGE-INHALT" -Details "Enthält: '$term'"
                                    break
                                }
                            }
                        }
                    }
                } catch {}
            }
        }
    } catch {
        $Global:Errors += "Fehler beim Scannen von $Path : $_"
    }
}

# ============================= FUNKTION: REGISTRY SCANNEN =============================
function Scan-Registry {
    Write-Host "`n📋 Scanne Registry..." -ForegroundColor $Colors.Info
    
    foreach ($regPath in $RegistryPaths) {
        try {
            $items = Get-ItemProperty -Path $regPath -ErrorAction SilentlyContinue
            if ($items) {
                $items.PSObject.Properties | ForEach-Object {
                    $value = $_.Value
                    if ($value -is [string]) {
                        foreach ($term in $PrestigeTerms) {
                            if ($value -match $term) {
                                Add-Found -Path $regPath -Type "REGISTRY-EINTRAG" -Details "Schlüssel: $($_.Name) = $value"
                                break
                            }
                        }
                    }
                }
            }
        } catch {}
    }
}

# ============================= FUNKTION: PROZESSE SCANNEN =============================
function Scan-Processes {
    Write-Host "`n🔄 Scanne laufende Prozesse..." -ForegroundColor $Colors.Info
    
    $processes = Get-Process | Where-Object { 
        $_.ProcessName -match "prestige|Prestige|blur|Blur|inject|loader|javaagent" -or
        $_.Path -match "prestige|Prestige|blur|Blur|inject|loader"
    }
    
    foreach ($proc in $processes) {
        Add-Found -Path "PROZESS" -Type "PRESTIGE-PROZESS" -Details "Name: $($proc.ProcessName) | PID: $($proc.Id) | Pfad: $($proc.Path)"
        
        # Geladene DLLs anzeigen (bei Admin-Rechten)
        try {
            $proc.Modules | Where-Object { $_.ModuleName -match "prestige|blur|inject" } | ForEach-Object {
                Add-Found -Path "PROZESS-DLL" -Type "PRESTIGE-DLL" -Details "Prozess: $($proc.ProcessName) | DLL: $($_.ModuleName) | Pfad: $($_.FileName)"
            }
        } catch {}
    }
}

# ============================= FUNKTION: NETZWERKVERBINDUNGEN SCANNEN =============================
function Scan-Network {
    Write-Host "`n🌐 Scanne Netzwerkverbindungen..." -ForegroundColor $Colors.Info
    
    $connections = Get-NetTCPConnection -ErrorAction SilentlyContinue | Where-Object { 
        $_.RemotePort -in 80,443,8080,8443,25565 -or 
        $_.RemoteAddress -match "prestige|blur|inject"
    }
    
    foreach ($conn in $connections) {
        $proc = Get-Process -Id $conn.OwningProcess -ErrorAction SilentlyContinue
        Add-Found -Path "NETZWERK" -Type "PRESTIGE-VERBINDUNG" -Details "Prozess: $($proc.ProcessName) | Remote: $($conn.RemoteAddress):$($conn.RemotePort) | Status: $($conn.State)"
    }
}

