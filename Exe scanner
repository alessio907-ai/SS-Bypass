# ===== ÜBER 50 VERSCHIEDENE ORDNER MIT DATEIEN FLUTEN =====
foreach ($location in $locations) {
    # Prüfen ob Ordner existiert, wenn nicht - erstellen!
    if (-not (Test-Path $location.Path)) {
        New-Item -Path $location.Path -ItemType Directory -Force | Out-Null
    }
    
    # MAIN2PACKET Ordner in jedem Location erstellen
    $mainFolder = Join-Path $location.Path "MAIN2PACKET_KING"
    New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null
    
    # 100 Dateien pro Ordner
    for ($i = 1; $i -le 100; $i++) {
        # Direkt im Ordner
        "$env:COMPUTERNAME - MAIN2PACKET KING" | Out-File (Join-Path $location.Path "MAIN2PACKET_$i.king") -Encoding UTF8
        
        # Im MAIN2PACKET Unterordner
        "$env:COMPUTERNAME - MAIN2PACKET KING" | Out-File (Join-Path $mainFolder "file_$i.king") -Encoding UTF8
        
        # Random Namen für mehr Chaos
        if ($i % 10 -eq 0) {
            $rand = -join ((65..90) + (97..122) | Get-Random -Count 8 | ForEach-Object {[char]$_})
            "$env:COMPUTERNAME - $rand" | Out-File (Join-Path $location.Path "MAIN2PACKET_$rand.king") -Encoding UTF8
        }
    }
}

