    Invoke-WebRequest -Uri $URL -OutFile "DownloadedWAVFile.wav"
    $filepath = ((Get-Childitem "DownloadedWAVFile.wav").FullName)
    $sound = new-Object System.Media.SoundPlayer;
    $sound.SoundLocation=$filepath;
    $sound.Play();
}

