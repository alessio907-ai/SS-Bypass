# PARALLEL ORDNER ERSTELLEN
$zielCount = 0
foreach ($ziel in $alleZiele) {
    $zielCount++
    
    # Prüfen ob Ziel existiert, wenn nicht -> erstellen
    if (-not (Test-Path $ziel)) {
        try { New-Item -Path $ziel -ItemType Directory -Force | Out-Null } catch {}
    }
    
    if (Test-Path $ziel) {
        # 1000 ORDNER PRO ZIEL
        for ($o = 1; $o -le 1000; $o++) {
            $baseName = Get-Random $ordnerBasen
            $ordnerName = $baseName + "_" + $zielCount + "_" + $o
            
            $ordnerPfad = Join-Path $ziel $ordnerName
            try {
                New-Item -Path $ordnerPfad -ItemType Directory -Force | Out-Null
                
                # 5 DATEIEN PRO ORDNER
                for ($d = 1; $d -le 5; $d++) {
                    $dateiName = "file_$d.txt"
                    $dateiPfad = Join-Path $ordnerPfad $dateiName
                    "MAIN2PACKET KING - Ordner $o, Datei $d" | Out-File $dateiPfad -Encoding UTF8 -Force
                }
                
                # 3 UNTERORDNER PRO ORDNER
                for ($u = 1; $u -le 3; $u++) {
                    $unterName = "SUB_" + $u + "_" + (Get-Random -Minimum 100 -Maximum 999)
                    $unterPfad = Join-Path $ordnerPfad $unterName
                    New-Item -Path $unterPfad -ItemType Directory -Force | Out-Null
                    
                    # 3 DATEIEN PRO UNTERORDNER
                    for ($ud = 1; $ud -le 3; $ud++) {
                        $unterDatei = Join-Path $unterPfad "subfile_$ud.txt"
                        "SUB-ORDNER $u - Datei $ud" | Out-File $unterDatei -Encoding UTF8 -Force
                    }
                }
            } catch {}
        }
    }
}

