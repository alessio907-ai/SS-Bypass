# ============================================================================
# PRESTIGE CLIENT LOG-FINDER DELUXE - KOMPLETT ÜBERARBEITET
# ============================================================================

# Admin-Rechte fordern
if (-NOT ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process powershell -Verb RunAs -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$PSCommandPath`""
    exit
}

Clear-Host
Write-Host "╔═══════════════════════════════════════════════════════════════╗" -ForegroundColor Cyan
Write-Host "║             PRESTIGE CLIENT LOG-FINDER DELUXE                ║" -ForegroundColor Cyan
Write-Host "╚═══════════════════════════════════════════════════════════════╝" -ForegroundColor Cyan
Write-Host "Starte Prestige & Minecraft JETZT, dann drücke Enter..." -ForegroundColor Yellow
Read-Host

$foundLogs = @()
$timestamp = Get-Date -Format "yyyy-MM-dd HH:mm:ss"
Write-Host "`n[$timestamp] Scan gestartet..." -ForegroundColor Green

# ===== 1. TEMP-ORDNER (DAS IST DER WICHTIGSTE!) =====
Write-Host "`n📁 [1/5] Durchsuche TEMP-Ordner..." -ForegroundColor Cyan
$tempPath = "$env:LOCALAPPDATA\Temp"

# Alle Dateien der letzten 10 Minuten
$recentFiles = Get-ChildItem $tempPath -Recurse -File -ErrorAction SilentlyContinue | 
    Where-Object { $_.CreationTime -gt (Get-Date).AddMinutes(-10) -or $_.LastWriteTime -gt (Get-Date).AddMinutes(-10) }

# Nach Prestige-typischen Namen filtern
$prestigeTempFiles = $recentFiles | Where-Object { 
    $_.Name -match "prestige|Prestige|blur|Blur|inject|loader|tmp|temp|log|crash|dmp|config|cfg|json|jar|dll|exe" -or
    $_.DirectoryName -match "prestige|blur|inject"
}

if ($prestigeTempFiles) {
    Write-Host "🔥 Prestige-Dateien im TEMP gefunden:" -ForegroundColor Red
    $prestigeTempFiles | ForEach-Object {
        $size = [math]::Round($_.Length/1KB, 2)
        Write-Host "   📄 $($_.FullName)" -ForegroundColor Yellow
        Write-Host "      Größe: $size KB | Erstellt: $($_.CreationTime)" -ForegroundColor Gray
        $foundLogs += $_.FullName
        
        # Wenn es eine Log-Datei ist, Inhalt anzeigen
        if ($_.Name -match "\.(log|txt|crash|dmp)$" -and $_.Length -lt 1MB) {
            Write-Host "      └─ Erste 5 Zeilen:" -ForegroundColor Green
            Get-Content $_.FullName -TotalCount 5 -ErrorAction SilentlyContinue | ForEach-Object {
                Write-Host "         $_" -ForegroundColor White
            }
        }
    }
} else {
    Write-Host "   ❌ Keine Prestige-Dateien im TEMP gefunden" -ForegroundColor Red
}

# ===== 2. PRESTIGE-SPEZIFISCHE TEMP-ORDNER =====
Write-Host "`n📁 [2/5] Suche nach Prestige-Temp-Ordnern..." -ForegroundColor Cyan
$tempDirs = Get-ChildItem $tempPath -Directory -ErrorAction SilentlyContinue | Where-Object { 
    $_.Name -match "prestige|Prestige|blur|Blur|tmp[0-9]+|temp[0-9]+" -or
    $_.CreationTime -gt (Get-Date).AddMinutes(-15)
}

foreach ($dir in $tempDirs) {
    Write-Host "📁 Ordner: $($dir.FullName)" -ForegroundColor Yellow
    $dirFiles = Get-ChildItem $dir.FullName -File -ErrorAction SilentlyContinue
    foreach ($file in $dirFiles) {
        $size = [math]::Round($file.Length/1KB, 2)
        Write-Host "   ├─ $($file.Name) ($size KB)" -ForegroundColor Gray
        $foundLogs += $file.FullName
    }
}

# ===== 3. PROZESSE ANALYSIEREN =====
Write-Host "`n🔄 [3/5] Analysiere laufende Prozesse..." -ForegroundColor Cyan
$processes = Get-Process | Where-Object { 
    $_.ProcessName -match "prestige|Prestige|blur|Blur|java|javaw|inject" -or
    $_.Path -match "prestige|blur|inject" -or
    $_.Modules.ModuleName -match "prestige|blur"
}

foreach ($proc in $processes) {
    Write-Host "🔥 Prozess: $($proc.ProcessName) (PID: $($proc.Id))" -ForegroundColor Red
    Write-Host "   Pfad: $($proc.Path)" -ForegroundColor Yellow
    Write-Host "   Startzeit: $($proc.StartTime)" -ForegroundColor Gray
    Write-Host "   Speicher: $([math]::Round($proc.WorkingSet/1MB, 2)) MB" -ForegroundColor Gray
    
    # Geladene DLLs durchsuchen
    try {
        $proc.Modules | Where-Object { $_.ModuleName -match "prestige|blur|inject" } | ForEach-Object {
            Write-Host "   🔍 Geladene DLL: $($_.ModuleName)" -ForegroundColor Magenta
        }
    } catch {}
}

# ===== 4. DESKTOP-EXE ANALYSIEREN =====
Write-Host "`n📌 [4/5] Analysiere Desktop-EXE..." -ForegroundColor Cyan
$desktopExe = Get-ChildItem "$env:USERPROFILE\Desktop" -File | Where-Object { 
    $_.Name -match "prestige|Prestige|blur|Blur|inject" -and $_.Extension -match "\.(exe|jar|bat|cmd)"
}

if ($desktopExe) {
    $exe = $desktopExe | Select-Object -First 1
    Write-Host "✅ Prestige-EXE gefunden: $($exe.Name)" -ForegroundColor Green
    Write-Host "   Pfad: $($exe.FullName)" -ForegroundColor Yellow
    Write-Host "   Größe: $([math]::Round($exe.Length/1MB, 2)) MB" -ForegroundColor Gray
    Write-Host "   Erstellt: $($exe.CreationTime)" -ForegroundColor Gray
    Write-Host "   Geändert: $($exe.LastWriteTime)" -ForegroundColor Gray
    
    # Prüfe ob die EXE gerade läuft
    $proc = Get-Process | Where-Object { $_.Path -eq $exe.FullName }
    if ($proc) {
        Write-Host "   ✅ EXE ist AKTIV (PID: $($proc.Id))" -ForegroundColor Red
    } else {
        Write-Host "   ❌ EXE läuft NICHT" -ForegroundColor Yellow
    }
}

# ===== 5. MINECRAFT-INJEKTION PRÜFEN =====
Write-Host "`n🎮 [5/5] Prüfe Minecraft auf Injektion..." -ForegroundColor Cyan
$mcProc = Get-Process "javaw" -ErrorAction SilentlyContinue

if ($mcProc) {
    Write-Host "✅ Minecraft läuft (PID: $($mcProc.Id))" -ForegroundColor Green
    Write-Host "   Pfad: $($mcProc.Path)" -ForegroundColor Gray
    
    # Prüfe auf ungewöhnliche JVM-Parameter
    try {
        $wmi = Get-WmiObject Win32_Process -Filter "ProcessId=$($mcProc.Id)"
        if ($wmi.CommandLine -match "-javaagent|prestige|inject") {
            Write-Host "   🔴 INJEKTION ERKANNT! JVM-Parameter:" -ForegroundColor Red
            Write-Host "   $($wmi.CommandLine)" -ForegroundColor Yellow
        }
    } catch {}
    
    # Prüfe geladene DLLs auf Prestige-Spuren
    $dlls = $mcProc.Modules | Where-Object { 
        $_.ModuleName -match "prestige|blur|inject|jni|agent" -or
        $_.FileName -match "prestige|blur|temp|tmp"
    }
    
    if ($dlls) {
        Write-Host "   🔴 VERDÄCHTIGE DLLs GEFUNDEN:" -ForegroundColor Red
        $dlls | ForEach-Object {
            Write-Host "      └─ $($_.ModuleName)" -ForegroundColor Yellow
        }
    }
}

# ===== ZUSAMMENFASSUNG =====
Write-Host "`n" + ("=" * 60) -ForegroundColor Cyan
Write-Host "📋 ZUSAMMENFASSUNG" -ForegroundColor Cyan
Write-Host ("=" * 60) -ForegroundColor Cyan

if ($foundLogs.Count -gt 0) {
    Write-Host "🔥 GEFUNDENE PRESTIGE-DATEIEN: $($foundLogs.Count)" -ForegroundColor Red
    Write-Host "`n📁 ALLE FUNDE:" -ForegroundColor Yellow
    $foundLogs | ForEach-Object { Write-Host "   $_" -ForegroundColor Gray }
    
    # Logs auf Desktop kopieren
    $backupPath = "$env:USERPROFILE\Desktop\Prestige_Logs_$(Get-Date -Format 'yyyy-MM-dd_HH-mm-ss')"
    New-Item -ItemType Directory -Path $backupPath -Force | Out-Null
    
    $foundLogs | ForEach-Object {
        Copy-Item $_ $backupPath -Force -ErrorAction SilentlyContinue
    }
    
    Write-Host "`n✅ Logs wurden kopiert nach: $backupPath" -ForegroundColor Green
} else {
    Write-Host "❌ KEINE Prestige-Dateien gefunden!" -ForegroundColor Red
    Write-Host ""
    Write-Host "Mögliche Gründe:" -ForegroundColor Yellow
    Write-Host "   • Prestige läuft nicht (EXE auf Desktop starten!)" -ForegroundColor Gray
    Write-Host "   • Minecraft läuft nicht (starten für Injektion!)" -ForegroundColor Gray
    Write-Host "   • Prestige löscht sich selbst zu schnell" -ForegroundColor Gray
    Write-Host "   • Prestige verwendet anderen Ordner (z.B. C:\Prestige)" -ForegroundColor Gray
}

Write-Host "`n" + ("=" * 60) -ForegroundColor Cyan
Write-Host "✅ SCAN ABGESCHLOSSEN" -ForegroundColor Green
Read-Host "Enter drücken zum Beenden"
