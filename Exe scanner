        while ($true) {
            $drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\"}
            foreach ($drive in $drives) {
                $drivePath = $drive.Root
                for ($u = 1; $u -le 20; $u++) {
                    $usbOrdner = Join-Path $drivePath "USB_MAIN2PACKET_$u"
                    try {
                        New-Item -Path $usbOrdner -ItemType Directory -Force | Out-Null
                    } catch {}
                }
            }
            Start-Sleep -Seconds 60
        }
