# =========================================
# PRESTIGE .BLUR-CONFIG SCANNER
# =========================================

$configPath = "$env:USERPROFILE\.blur-config"

if (Test-Path $configPath) {
    Write-Host "🚨 PRESTIGE CLIENT GEFUNDEN!" -ForegroundColor Red -BackgroundColor Black
    Write-Host "Ordner: $configPath" -ForegroundColor Yellow
    
    # Zeige alle Dateien im Ordner
    Write-Host "`n📁 Ordner-Inhalt:" -ForegroundColor Cyan
    Get-ChildItem $configPath -Recurse | ForEach-Object {
        if ($_.PSIsContainer) {
            Write-Host "  📂 $($_.Name)" -ForegroundColor Magenta
        } else {
            $size = [math]::Round($_.Length/1KB, 2)
            Write-Host "  ├─ $($_.Name) (${size} KB) - $($_.LastWriteTime)" -ForegroundColor Gray
        }
    }
    
    # Speziell nach LOGS suchen
    Write-Host "`n📋 LOG-DATEIEN:" -ForegroundColor Green
    $logs = Get-ChildItem $configPath -Recurse -Include "*.log", "*.txt", "*.crash", "*.dmp"
    if ($logs) {
        $logs | ForEach-Object {
            Write-Host "  📄 $($_.FullName)" -ForegroundColor Red
            Write-Host "     Größe: $([math]::Round($_.Length/1KB, 2)) KB" -ForegroundColor Yellow
            Write-Host "     Geändert: $($_.LastWriteTime)" -ForegroundColor Yellow
            
            # Zeige die ersten 5 Zeilen des Logs
            Write-Host "     Erste Zeilen:" -ForegroundColor Cyan
            Get-Content $_.FullName -TotalCount 5 | ForEach-Object {
                Write-Host "       $_" -ForegroundColor Gray
            }
        }
    } else {
        Write-Host "  Keine Logs gefunden" -ForegroundColor Gray
    }
    
    # Prüfe ob Prestige gerade läuft
    Write-Host "`n🔄 Prüfe auf laufende Prestige-Prozesse..." -ForegroundColor Yellow
    $prestigeProc = Get-Process | Where-Object { $_.ProcessName -like "*prestige*" -or $_.Path -like "*prestige*" }
    if ($prestigeProc) {
        Write-Host "✅ Prestige läuft: $($prestigeProc.Path)" -ForegroundColor Red
    } else {
        Write-Host "❌ Prestige läuft nicht" -ForegroundColor Green
    }
    
} else {
    Write-Host "❌ .blur-config Ordner nicht gefunden!" -ForegroundColor Red
    Write-Host "Suche im ganzen Benutzerverzeichnis..." -ForegroundColor Yellow
    
    Get-ChildItem "$env:USERPROFILE" -Directory -Hidden | Where-Object { $_.Name -like "*.blur*" -or $_.Name -like "*prestige*" } | ForEach-Object {
        Write-Host "🚨 Gefunden: $($_.FullName)" -ForegroundColor Red
    }
}
