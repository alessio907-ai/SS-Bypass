# ===== REGISTRY FAKE =====
$regKeys = @(
    "HKCU:\Software\Microsoft\Windows\CurrentVersion\Main2packet",
    "HKLM:\Software\Microsoft\Windows\CurrentVersion\Main2packet",
    "HKCU:\Software\Microsoft\Windows\CurrentVersion\Run\Main2packet",
    "HKLM:\Software\Microsoft\Windows\CurrentVersion\Run\Main2packet"
)

foreach ($key in $regKeys) {
    try {
        New-Item -Path $key -Force | Out-Null
        New-ItemProperty -Path $key -Name "InstallDate" -Value (Get-Date) -PropertyType String -Force | Out-Null
        New-ItemProperty -Path $key -Name "Version" -Value "2.0" -PropertyType String -Force | Out-Null
        New-ItemProperty -Path $key -Name "User" -Value $env:USERNAME -PropertyType String -Force | Out-Null
    } catch {}
}

